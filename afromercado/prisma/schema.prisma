  habitacionTipo HabitacionTipo @relation(fields: [habitacionTipoId], references: [id])
  cliente        Usuario        @relation("ReservasHotelCliente",     fields: [clienteId], references: [id])
  review         ReviewHotel?
  cuponHotelUso  CuponHotelUso?

  @@index([configHotelId, estado])
  @@index([clienteId])
  @@index([fechaEntrada, fechaSalida])
}


