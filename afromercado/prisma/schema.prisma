model SolicitudPublicidad {
  id             Int      @id @default(autoincrement())
  comercioId     Int
  productoId     Int?
  paquete        String
  objetivo       String
  presupuestoCOP Decimal? @db.Decimal(12, 2)
  alcance        String   @default("NACIONAL") // "MUNICIPIO" | "DEPARTAMENTO" | "NACIONAL"
  departamento   String?
  municipio      String?
  inicio         DateTime?
  fin            DateTime?
  mensaje        String?
  estado         String   @default("PENDIENTE")
  notasAdmin     String?
  politicaAceptada Boolean @default(false)
  politicaVersion  String?
  politicaAceptadaAt DateTime?
  politicaIp       String?
  pagoEstado       String        @default("PENDIENTE")
  pagoMontoCOP     Decimal?      @db.Decimal(12, 2)
  pagoReferencia   String?       @unique
  pagoProveedor    ProveedorPago?
  pagoCheckoutUrl  String?
  pagoProviderPaymentId String?  @unique
  pagoProviderReference String?  @unique
  pagoProviderStatus String?
  pagoProviderPayload Json?
  pagoConfirmadoAt DateTime?
  pagoExpiraAt     DateTime?
  pagoNotas        String?
  pagoActualizadoPor Int?
  pagoActualizadoAt DateTime?
  revisadoPor    Int?
  revisadoAt     DateTime?

  // Editorial Video/Historia
  videoUrl             String?
  videoPortadaUrl      String?
  videoTexto           String?
  videoUbicacion       String?
  videoDestino         String?
  videoNotasComercio   String?
  videoAprobado        Boolean?
  videoNotasRevision   String?
  videoRevisadoPor     Int?
  videoRevisadoAt      DateTime?

  // Imagen diseñada propia (BANNER_CARRUSEL / IRRUPTOR_BIENVENIDA) — mismo patrón que videoUrl.
  imagenPersonalizadaUrl String?

  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  comercio     Comercio  @relation(fields: [comercioId], references: [id])
  producto     Producto? @relation(fields: [productoId], references: [id])
  adminRevisor Usuario?  @relation("SolicitudPublicidadRevisor", fields: [revisadoPor], references: [id])

  @@index([estado, createdAt])
  @@index([pagoEstado, createdAt])
  @@index([pagoProveedor, pagoEstado])
  @@index([comercioId, createdAt])
  @@index([productoId])
}

model AuditoriaAfroMedia {
  id          Int      @id @default(autoincrement())
  tipo        String
  entidad     String
  entidadId   Int?
  usuarioId   Int?
  datos       Json?
  ip          String?
  createdAt   DateTime @default(now())

  @@index([tipo, createdAt])
  @@index([entidad, entidadId, createdAt])
  @@index([usuarioId, createdAt])
}

model PublicidadPaqueteConfig {
  id            Int      @id @default(autoincrement())
  codigo        String   @unique
  nombre        String
  descripcion   String?
  ideal         String?
  precioBaseCOP Decimal  @default(0) @db.Decimal(12, 2)
  duracionDias  Int      @default(7)
  cuposSugeridos Int?
  activo        Boolean  @default(true)
  recomendado   Boolean  @default(false)
  orden         Int      @default(0)
  color         String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([activo, orden])
}

model PushSubscripcion {
  id        Int      @id @default(autoincrement())
  usuarioId Int
  endpoint  String   @unique
  p256dh    String
  auth      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  usuario   Usuario  @relation(fields: [usuarioId], references: [id], onDelete: Cascade)

  @@index([usuarioId])
}

model ComisionComercio {
  id         Int       @id @default(autoincrement())
  comercioId Int
  tasa       Decimal   @db.Decimal(5, 4)
  motivo     String?
  desde      DateTime  @default(now())
  hasta      DateTime?
  creadoPor  Int
  createdAt  DateTime  @default(now())

  comercio Comercio @relation(fields: [comercioId], references: [id])

  @@index([comercioId, hasta])
}

model AccionModeracion {
  id         Int      @id @default(autoincrement())
  adminId    Int
  targetId   Int
  targetTipo String
  accion     String
  motivo     String?
  createdAt  DateTime @default(now())

  @@index([targetId, targetTipo, createdAt])
}

model Liquidacion {
  id             Int               @id @default(autoincrement())
  tipo           TipoLiquidacion
  beneficiarioId Int
  monto          Decimal           @db.Decimal(10, 2)
  estado         EstadoLiquidacion @default(PENDIENTE)
  periodoDesde   DateTime
  periodoHasta   DateTime
  cuentaDestino  String?
  comprobante    String?
  notas          String?
  creadoPor      Int
  pagadoPor      Int?
  pagadoAt       DateTime?
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt

  beneficiario    Usuario   @relation("LiquidacionBeneficiario", fields: [beneficiarioId], references: [id])
  adminCreador    Usuario   @relation("LiquidacionAdmin", fields: [creadoPor], references: [id])
  adminPagador    Usuario?  @relation("LiquidacionPagador", fields: [pagadoPor], references: [id])

  @@index([beneficiarioId, estado])
  @@index([tipo, estado, createdAt])
}

// ─── PEDIDO EXPRESS ───────────────────────────────────────────

enum ModalidadExpress {
  DOMICILIO
  RECOGER
  MESA
}

enum EstadoPedidoExpress {
  PENDIENTE
  ACEPTADO
  EN_PREPARACION
  LISTO
  EN_CAMINO
  ENTREGADO
  CANCELADO
  RECHAZADO
}

enum MetodoPagoExpress {
  EFECTIVO
  NEQUI
  WOMPI
}

model ConfigExpress {
  id         Int      @id @default(autoincrement())
  comercioId Int      @unique
  activo     Boolean  @default(false)
  abierto    Boolean  @default(false)
  tiempoPrepMinutos Int      @default(20)
  municipiosEntrega String[]
  modalidades       ModalidadExpress[]
  costoEnvioBase    Decimal  @default(3000) @db.Decimal(10, 2)
  limiteCreditoEfectivo Decimal @default(30000) @db.Decimal(10, 2)
  deudaEfectivoActual   Decimal @default(0)   @db.Decimal(10, 2)
  videoUrl       String?
  videoPosterUrl String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  comercio        Comercio         @relation(fields: [comercioId], references: [id])
  pedidosExpress  PedidoExpress[]
  horarios        HorarioExpress[]
  secciones       MenuSeccion[]
  cupones         CuponExpress[]
  reviews         ReviewExpress[]
  favoritos       FavoritoExpress[]

  @@index([activo, abierto])
}

model MenuSeccion {
  id              Int           @id @default(autoincrement())
  configExpressId Int
  nombre          String
  icono           String        @default("🍽️")
  orden           Int           @default(0)
  activo          Boolean       @default(true)
  vistaCompacta   Boolean       @default(false)
  createdAt       DateTime      @default(now())

  configExpress   ConfigExpress @relation(fields: [configExpressId], references: [id], onDelete: Cascade)
  productos       Producto[]    @relation("ProductoMenuSeccion")

  @@index([configExpressId, activo])
}

enum DiaSemana {
  LUNES
  MARTES
  MIERCOLES
  JUEVES
  VIERNES
  SABADO
  DOMINGO
  FESTIVO
}

model HorarioExpress {
  id              Int           @id @default(autoincrement())
  configExpressId Int
  dia             DiaSemana
  abierto         Boolean       @default(true)
  apertura        String        // HH:MM
  cierre          String        // HH:MM

  configExpress   ConfigExpress @relation(fields: [configExpressId], references: [id], onDelete: Cascade)

  @@unique([configExpressId, dia])
  @@index([configExpressId])
}

model PedidoExpress {
  id               Int                 @id @default(autoincrement())
  codigo           String              @unique
  comercioId       Int
  clienteId        Int
  repartidorId     Int?
  configExpressId  Int

  modalidad        ModalidadExpress
  estado           EstadoPedidoExpress @default(PENDIENTE)
  metodoPago       MetodoPagoExpress
  pagoConfirmado   Boolean             @default(false)

  subtotal         Decimal             @db.Decimal(12, 2)
  costoEnvio       Decimal             @default(0) @db.Decimal(10, 2)
  comision         Decimal             @db.Decimal(12, 2)
  montoDescuento   Decimal?            @db.Decimal(10, 2)
  codigoCupon      String?
  total            Decimal             @db.Decimal(12, 2)

  direccionTexto   String?
  municipioEntrega String?
  notaCliente      String?
  motivoCancelacion String?

  fechaProgramada  DateTime?          // null = pedido inmediato; si viene, hora futura dentro de un horario de apertura válido

  tiempoEstimadoMin Int               @default(30)
  tiempoAjustadoMin Int?

  creadoAt         DateTime            @default(now())
  aceptadoAt       DateTime?
  preparandoAt     DateTime?
  listoAt          DateTime?
  enCaminoAt       DateTime?
  entregadoAt      DateTime?
  canceladoAt      DateTime?
  expiresAt        DateTime

  cliente          Usuario             @relation("PedidosExpressCliente",    fields: [clienteId],      references: [id])
  repartidor       Usuario?            @relation("PedidosExpressRepartidor", fields: [repartidorId],   references: [id])
  configExpress    ConfigExpress       @relation(fields: [configExpressId],  references: [id])
  items            ItemPedidoExpress[]
  cuponUso         CuponExpressUso?
  review           ReviewExpress?

  @@index([comercioId, estado])
  @@index([clienteId,  estado])
  @@index([estado, creadoAt])
}

model ItemPedidoExpress {
  id              Int           @id @default(autoincrement())
  pedidoExpressId Int
  productoId      Int
  cantidad        Int
  precioUnitario  Decimal       @db.Decimal(12, 2)
  subtotal        Decimal       @db.Decimal(12, 2)
  nota            String?
  complementos    Json?

  pedidoExpress   PedidoExpress @relation(fields: [pedidoExpressId], references: [id])
  producto        Producto      @relation(fields: [productoId],      references: [id])

  @@index([pedidoExpressId])
}

model GrupoComplemento {
  id         Int      @id @default(autoincrement())
  productoId Int
  nombre     String
  minimo     Int      @default(0)
  maximo     Int      @default(1)
  requerido  Boolean  @default(false)
  orden      Int      @default(0)
  activo     Boolean  @default(true)

  producto Producto          @relation(fields: [productoId], references: [id], onDelete: Cascade)
  items    ItemComplemento[]

  @@index([productoId])
}

model ItemComplemento {
  id                 Int     @id @default(autoincrement())
  grupoComplementoId Int
  nombre             String
  icono              String?
  imagenUrl          String?
  precio             Decimal @default(0) @db.Decimal(12, 2)
  disponible         Boolean @default(true)
  orden              Int     @default(0)

  grupo GrupoComplemento @relation(fields: [grupoComplementoId], references: [id], onDelete: Cascade)

  @@index([grupoComplementoId])
}

// ─── MÓDULO HOTELERÍA ─────────────────────────────────────────

model GrupoComplementoBiblioteca {
  id         Int      @id @default(autoincrement())
  comercioId Int
  nombre     String
  minimo     Int      @default(0)
  maximo     Int      @default(1)
  requerido  Boolean  @default(false)
  orden      Int      @default(0)
  activo     Boolean  @default(true)
  creadoAt   DateTime @default(now())
  updatedAt  DateTime @updatedAt

  comercio Comercio @relation(fields: [comercioId], references: [id], onDelete: Cascade)
  items    ItemComplementoBiblioteca[]
  productos ProductoGrupoComplemento[]

  @@unique([comercioId, nombre])
  @@index([comercioId])
}

model ItemComplementoBiblioteca {
  id                 Int     @id @default(autoincrement())
  grupoBibliotecaId  Int
  nombre             String
  icono              String?
  imagenUrl          String?
  precio             Decimal @default(0) @db.Decimal(12, 2)
  disponible         Boolean @default(true)
  orden              Int     @default(0)

  grupo GrupoComplementoBiblioteca @relation(fields: [grupoBibliotecaId], references: [id], onDelete: Cascade)

  @@index([grupoBibliotecaId])
}

model ProductoGrupoComplemento {
  id                 Int      @id @default(autoincrement())
  productoId         Int
  grupoBibliotecaId  Int
  minimoOverride     Int?
  maximoOverride     Int?
  requeridoOverride  Boolean?
  orden              Int      @default(0)
  activo             Boolean  @default(true)
  creadoAt           DateTime @default(now())

  producto Producto @relation(fields: [productoId], references: [id], onDelete: Cascade)
  grupo    GrupoComplementoBiblioteca @relation(fields: [grupoBibliotecaId], references: [id], onDelete: Cascade)

  @@unique([productoId, grupoBibliotecaId])
  @@index([productoId])
  @@index([grupoBibliotecaId])
}

enum EstadoReservaHotel {
  PENDIENTE
  CONFIRMADA
  CHECKIN
  CHECKOUT
  CANCELADA
  RECHAZADA
}

model ConfigHotel {
  id                      Int       @id @default(autoincrement())
  comercioId              Int       @unique
  activo                  Boolean   @default(false)
  confirmacionAuto        Boolean   @default(false)
  horasLimiteConfirm      Int       @default(2)
  servicios               String[]
  politicaCancelacion     String?
  checkInHora             String    @default("15:00")
  checkOutHora            String    @default("12:00")
  // Política de pagos
  permitePagarAlLlegar    Boolean   @default(true)
  permiteDeposito30       Boolean   @default(true)
  permiteTotal            Boolean   @default(true)
  permiteReservasPorHora  Boolean   @default(false)
  minutosLimpiezaEntreReservas Int   @default(30)
  // Política de cancelación con penalización
  horasLibresCancelacion  Int       @default(48)
  pctPenalidadCancelacion Int       @default(0)
  rnt                     String?
  rntVerificado           Boolean   @default(false)
  creadoAt                DateTime  @default(now())
  updatedAt               DateTime  @updatedAt

  comercio      Comercio         @relation(fields: [comercioId], references: [id])
  habitaciones  HabitacionTipo[]
  habitacionesFisicas HabitacionFisica[]
  reservas      ReservaHotel[]
  reviews       ReviewHotel[]
  cupones       CuponHotel[]
  temporadas    TemporadaHotel[]
  favoritos     FavoritoHotel[]

  @@index([activo])
}

model HabitacionTipo {
  id              Int         @id @default(autoincrement())
  configHotelId   Int
  nombre          String
  descripcion     String?
  capacidad       Int         @default(2)
  precioPorNoche  Decimal     @db.Decimal(12, 2)
  precioPorHora   Decimal?    @db.Decimal(12, 2)
  permitePorHoras Boolean     @default(false)
  duracionMinHoras Int        @default(2)
  duracionMaxHoras Int?
  cantidad        Int         @default(1)
  fotos            String[]
  serviciosExtra   String[]
  activo           Boolean     @default(true)
  creadoAt         DateTime    @default(now())
  videoUrl         String?
  videoPosterUrl   String?
  videoDuracionSeg Int?

  configHotel ConfigHotel    @relation(fields: [configHotelId], references: [id], onDelete: Cascade)
  reservas    ReservaHotel[]
  temporadas  TemporadaHotel[]
  unidadesFisicas HabitacionFisica[]

  @@index([configHotelId, activo])
}

model HabitacionFisica {
  id               Int      @id @default(autoincrement())
  configHotelId    Int
  habitacionTipoId Int
  nombre           String
  piso             String?
  zona             String?
  estado           String   @default("LIBRE")
  notas            String?
  activo           Boolean  @default(true)
  creadoAt         DateTime @default(now())
  updatedAt        DateTime @updatedAt

  configHotel    ConfigHotel    @relation(fields: [configHotelId], references: [id], onDelete: Cascade)
  habitacionTipo HabitacionTipo @relation(fields: [habitacionTipoId], references: [id], onDelete: Cascade)
  reservas       ReservaHotel[]

  @@unique([habitacionTipoId, nombre])
  @@index([configHotelId, estado])
  @@index([habitacionTipoId, activo])
}

model ReservaHotel {
  id                Int                @id @default(autoincrement())
  codigo            String             @unique
  configHotelId     Int
  habitacionTipoId  Int
  habitacionFisicaId Int?
  clienteId         Int
  fechaEntrada      DateTime
  fechaSalida       DateTime
  huespedes         Int                @default(1)
  total             Decimal            @db.Decimal(12, 2)
  modalidad         String             @default("NOCHE")
  duracionHoras     Decimal?           @db.Decimal(6, 2)
  estado            EstadoReservaHotel @default(PENDIENTE)
  metodoPago        String             @default("EFECTIVO")
  notasCliente      String?
  nombreHuesped     String
  telefonoHuesped   String
  // Descuentos, penalizaciones y reembolsos
  montoDescuento    Decimal?           @db.Decimal(10, 2)
  montoPenalidad    Decimal?           @db.Decimal(10, 2)
  montoReembolso    Decimal?           @db.Decimal(10, 2)
  codigoCupon       String?
  comision          Decimal?           @db.Decimal(10, 2)
  tasaComision      Decimal?           @db.Decimal(5, 4)
  checkinOnlineAt       DateTime?
  docTipo               String?
  docNumero             String?
  horaEstimadaLlegada   String?
  solicitudesEspeciales String?
  tokenCheckin          String?        @unique
  // Reserva grupal: comparte el mismo valor entre las N reservas creadas juntas
  // en una sola solicitud (varios tipos de habitación). null = reserva individual.
  grupoReservaId        String?
  creadoAt          DateTime           @default(now())
  updatedAt         DateTime           @updatedAt

  configHotel    ConfigHotel    @relation(fields: [configHotelId],    references: [id])
  habitacionTipo HabitacionTipo @relation(fields: [habitacionTipoId], references: [id])
  habitacionFisica HabitacionFisica? @relation(fields: [habitacionFisicaId], references: [id])
  cliente        Usuario        @relation("ReservasHotelCliente",     fields: [clienteId], references: [id])
  review         ReviewHotel?
  cuponHotelUso  CuponHotelUso?

  @@index([configHotelId, estado])
  @@index([habitacionFisicaId])
  @@index([clienteId])
  @@index([fechaEntrada, fechaSalida])
  @@index([grupoReservaId])
}


// ─── MÓDULO TOURS ─────────────────────────────────────────────

enum EstadoReservaTour {
  PENDIENTE
  CONFIRMADA
  CANCELADA
  RECHAZADA
  COMPLETADA
}

model ConfigTour {
  id                  Int      @id @default(autoincrement())
  comercioId          Int      @unique
  activo              Boolean  @default(false)
  nombre              String   @default("Tour")
  descripcion         String?
  duracionHoras       Float    @default(2)
  precioPersona       Decimal  @db.Decimal(12, 2)
  maxParticipantes    Int      @default(10)
  puntoEncuentro      String?
  fotos               String[]
  videoUrl            String?
  videoPosterUrl      String?
  servicios           String[]
  idiomas             String[]
  confirmacionAuto    Boolean  @default(false)
  horasLimiteConfirm  Int      @default(2)
  politicaCancelacion String?
  rnt                 String?
  rntVerificado       Boolean  @default(false)
  creadoAt            DateTime @default(now())
  updatedAt           DateTime @updatedAt

  comercio  Comercio       @relation(fields: [comercioId], references: [id])
  lugares   TourLugar[]
  reservas  ReservaTour[]
  reviews   ReviewTour[]
  cupones   CuponTour[]
  favoritos FavoritoTour[]

  @@index([activo])
}

model TourLugar {
  id              Int      @id @default(autoincrement())
  configTourId    Int
  titulo          String
  descripcion     String?
  tipo            String?
  rutaNombre      String?
  orden           Int      @default(0)
  duracionMinutos Int?
  recomendaciones String?
  latitud         Float?
  longitud        Float?
  activo          Boolean  @default(true)
  destacado       Boolean  @default(false)
  creadoAt        DateTime @default(now())
  updatedAt       DateTime @updatedAt

  configTour ConfigTour       @relation(fields: [configTourId], references: [id], onDelete: Cascade)
  media      TourLugarMedia[]

  @@index([configTourId, orden])
  @@index([configTourId, activo])
}

model TourLugarMedia {
  id              Int      @id @default(autoincrement())
  tourLugarId     Int
  tipo            String
  url             String
  posterUrl       String?
  titulo          String?
  descripcion     String?
  plataforma      String?
  orden           Int      @default(0)
  activo          Boolean  @default(true)
  publicId        String?
  duracionSegundos Float?
  bytes           Int?
  formato         String?
  mimeType        String?
  creadoAt        DateTime @default(now())
  updatedAt       DateTime @updatedAt

  tourLugar TourLugar @relation(fields: [tourLugarId], references: [id], onDelete: Cascade)

  @@index([tourLugarId, orden])
  @@index([tipo])
}

model ReservaTour {
  id               Int                @id @default(autoincrement())
  codigo           String             @unique
  configTourId     Int
  clienteId        Int
  fechaTour        DateTime
  participantes    Int                @default(1)
  total            Decimal            @db.Decimal(12, 2)
  estado           EstadoReservaTour  @default(PENDIENTE)
  metodoPago       String             @default("EFECTIVO")
  notasCliente     String?
  nombreContacto   String
  telefonoContacto String
  comision         Decimal?           @db.Decimal(10, 2)
  tasaComision     Decimal?           @db.Decimal(5, 4)
  montoDescuento   Decimal?           @db.Decimal(10, 2)
  codigoCupon      String?
  creadoAt         DateTime           @default(now())
  updatedAt        DateTime           @updatedAt

  configTour   ConfigTour    @relation(fields: [configTourId], references: [id])
  cliente      Usuario       @relation("ReservasTourCliente", fields: [clienteId], references: [id])
  review       ReviewTour?
  cuponTourUso CuponTourUso?

  @@index([configTourId, estado])
  @@index([clienteId])
  @@index([fechaTour])
}

// ─── MÓDULO TRANSPORTE FLUVIAL ────────────────────────────────

model ConfigTransporte {
  id          Int      @id @default(autoincrement())
  comercioId  Int      @unique
  activo      Boolean  @default(false)
  nombre      String   @default("Mi Servicio")
  descripcion String?
  tipo        String   @default("LANCHA")
  fotos          String[]
  videoUrl       String?
  videoPosterUrl String?
  creadoAt       DateTime @default(now())
  updatedAt      DateTime @updatedAt

  comercio   Comercio            @relation(fields: [comercioId], references: [id])
  rutas      RutaTransporte[]
  reviews    ReviewTransporte[]
  favoritos  FavoritoTransporte[]
  cupones    CuponTransporte[]

  @@index([activo])
}

model RutaTransporte {
  id                  Int      @id @default(autoincrement())
  configTransporteId  Int
  origen              String
  destino             String
  horario             String
  diasSemana          String[]
  capacidad           Int      @default(10)
  precioAsiento       Decimal  @db.Decimal(12, 2)
  activo              Boolean  @default(true)
  creadoAt            DateTime @default(now())

  configTransporte ConfigTransporte    @relation(fields: [configTransporteId], references: [id], onDelete: Cascade)
  reservas         ReservaTransporte[]

  @@index([configTransporteId, activo])
}

enum EstadoReservaTransporte {
  PENDIENTE
  CONFIRMADA
  CANCELADA
  RECHAZADA
  COMPLETADA
}

model ReservaTransporte {
  id               Int                     @id @default(autoincrement())
  codigo           String                  @unique
  rutaTransporteId Int
  clienteId        Int
  fechaViaje       DateTime
  asientos         Int                     @default(1)
  total            Decimal                 @db.Decimal(12, 2)
  estado           EstadoReservaTransporte @default(PENDIENTE)
  metodoPago       String                  @default("EFECTIVO")
  notasCliente     String?
  nombreContacto   String
  telefonoContacto String
  montoDescuento   Decimal?                @db.Decimal(10, 2)
  codigoCupon      String?
  creadoAt         DateTime                @default(now())
  updatedAt        DateTime                @updatedAt

  ruta          RutaTransporte     @relation(fields: [rutaTransporteId], references: [id])
  cliente       Usuario            @relation("ReservasTransporteCliente", fields: [clienteId], references: [id])
  review        ReviewTransporte?
  cuponTransporteUso CuponTransporteUso?

  @@index([rutaTransporteId, estado])
  @@index([clienteId])
  @@index([fechaViaje])
