  fin              DateTime
  precioPorNoche   Decimal   @db.Decimal(12, 2)
  activo           Boolean   @default(true)
  createdAt        DateTime  @default(now())

  configHotel    ConfigHotel     @relation(fields: [configHotelId], references: [id], onDelete: Cascade)
  habitacionTipo HabitacionTipo? @relation(fields: [habitacionTipoId], references: [id], onDelete: SetNull)

  @@index([configHotelId, activo])
  @@index([habitacionTipoId, activo])
  @@index([inicio, fin])
}

model FavoritoHotel {
  id            Int      @id @default(autoincrement())
  usuarioId     Int
  configHotelId Int
  createdAt     DateTime @default(now())

  usuario     Usuario     @relation(fields: [usuarioId],     references: [id], onDelete: Cascade)
  configHotel ConfigHotel @relation(fields: [configHotelId], references: [id], onDelete: Cascade)

  @@unique([usuarioId, configHotelId])
  @@index([usuarioId])
  @@index([configHotelId])
}
