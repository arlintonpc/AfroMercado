  estado            EstadoReservaHotel @default(PENDIENTE)
  metodoPago        String             @default("EFECTIVO")
  notasCliente      String?
  nombreHuesped     String
  telefonoHuesped   String
  // Descuentos, penalizaciones y reembolsos
  montoDescuento    Decimal?           @db.Decimal(10, 2)
  montoPenalidad    Decimal?           @db.Decimal(10, 2)
  montoReembolso    Decimal?           @db.Decimal(10, 2)
  codigoCupon       String?
  comision          Decimal?           @db.Decimal(10, 2)
  tasaComision      Decimal?           @db.Decimal(5, 4)
  checkinOnlineAt       DateTime?
  docTipo               String?
  docNumero             String?
  horaEstimadaLlegada   String?
  solicitudesEspeciales String?
  tokenCheckin          String?        @unique
  // Reserva grupal: comparte el mismo valor entre las N reservas creadas juntas
  // en una sola solicitud (varios tipos de habitación). null = reserva individual.
  grupoReservaId        String?
  creadoAt          DateTime           @default(now())
  updatedAt         DateTime           @updatedAt

  configHotel    ConfigHotel    @relation(fields: [configHotelId],    references: [id])
  habitacionTipo HabitacionTipo @relation(fields: [habitacionTipoId], references: [id])
  habitacionFisica HabitacionFisica? @relation(fields: [habitacionFisicaId], references: [id])
  cliente        Usuario        @relation("ReservasHotelCliente",     fields: [clienteId], references: [id])

  @@index([configHotelId, estado])
  @@index([habitacionFisicaId])
  @@index([clienteId])
  @@index([fechaEntrada, fechaSalida])
  @@index([grupoReservaId])
}


// ─── MÓDULO TOURS ─────────────────────────────────────────────

enum EstadoReservaTour {
  PENDIENTE
  CONFIRMADA
  CANCELADA
  RECHAZADA
  COMPLETADA
}

model ConfigTour {
  id                  Int      @id @default(autoincrement())
  comercioId          Int      @unique
  activo              Boolean  @default(false)
  nombre              String   @default("Tour")
  descripcion         String?
  duracionHoras       Float    @default(2)
  precioPersona       Decimal  @db.Decimal(12, 2)
  maxParticipantes    Int      @default(10)
  puntoEncuentro      String?
  fotos               String[]
  videoUrl            String?
  videoPosterUrl      String?
  servicios           String[]
  idiomas             String[]
  confirmacionAuto    Boolean  @default(false)
  horasLimiteConfirm  Int      @default(2)
  politicaCancelacion String?
  rnt                 String?
  rntVerificado       Boolean  @default(false)
  creadoAt            DateTime @default(now())
  updatedAt           DateTime @updatedAt

  comercio  Comercio       @relation(fields: [comercioId], references: [id])
  lugares   TourLugar[]
  reservas  ReservaTour[]

  @@index([activo])
}

model TourLugar {
  id              Int      @id @default(autoincrement())
  configTourId    Int
  titulo          String
  descripcion     String?
  tipo            String?
  rutaNombre      String?
  orden           Int      @default(0)
  duracionMinutos Int?
  recomendaciones String?
  latitud         Float?
  longitud        Float?
  activo          Boolean  @default(true)
  destacado       Boolean  @default(false)
  creadoAt        DateTime @default(now())
  updatedAt       DateTime @updatedAt

  configTour ConfigTour       @relation(fields: [configTourId], references: [id], onDelete: Cascade)
  media      TourLugarMedia[]

  @@index([configTourId, orden])
  @@index([configTourId, activo])
}

model TourLugarMedia {
  id              Int      @id @default(autoincrement())
  tourLugarId     Int
  tipo            String
  url             String
  posterUrl       String?
  titulo          String?
  descripcion     String?
  plataforma      String?
  orden           Int      @default(0)
  activo          Boolean  @default(true)
  publicId        String?
  duracionSegundos Float?
  bytes           Int?
  formato         String?
  mimeType        String?
  creadoAt        DateTime @default(now())
  updatedAt       DateTime @updatedAt

  tourLugar TourLugar @relation(fields: [tourLugarId], references: [id], onDelete: Cascade)

  @@index([tourLugarId, orden])
  @@index([tipo])
}

model ReservaTour {
  id               Int                @id @default(autoincrement())
  codigo           String             @unique
  configTourId     Int
  clienteId        Int
  fechaTour        DateTime
  participantes    Int                @default(1)
  total            Decimal            @db.Decimal(12, 2)
  estado           EstadoReservaTour  @default(PENDIENTE)
  metodoPago       String             @default("EFECTIVO")
  notasCliente     String?
  nombreContacto   String
  telefonoContacto String
  comision         Decimal?           @db.Decimal(10, 2)
  tasaComision     Decimal?           @db.Decimal(5, 4)
  montoDescuento   Decimal?           @db.Decimal(10, 2)
  codigoCupon      String?
  creadoAt         DateTime           @default(now())
  updatedAt        DateTime           @updatedAt

  configTour   ConfigTour    @relation(fields: [configTourId], references: [id])
  cliente      Usuario       @relation("ReservasTourCliente", fields: [clienteId], references: [id])

  @@index([configTourId, estado])
  @@index([clienteId])
  @@index([fechaTour])
}

// ─── MÓDULO TRANSPORTE FLUVIAL ────────────────────────────────

model ConfigTransporte {
  id          Int      @id @default(autoincrement())
  comercioId  Int      @unique
  activo      Boolean  @default(false)
  nombre      String   @default("Mi Servicio")
  descripcion String?
  tipo        String   @default("LANCHA")
  fotos          String[]
  videoUrl       String?
  videoPosterUrl String?
  creadoAt       DateTime @default(now())
  updatedAt      DateTime @updatedAt

  comercio   Comercio            @relation(fields: [comercioId], references: [id])
  rutas      RutaTransporte[]

  @@index([activo])
}

model RutaTransporte {
  id                  Int      @id @default(autoincrement())
  configTransporteId  Int
  origen              String
  destino             String
  horario             String
  diasSemana          String[]
  capacidad           Int      @default(10)
  precioAsiento       Decimal  @db.Decimal(12, 2)
  activo              Boolean  @default(true)
  creadoAt            DateTime @default(now())

  configTransporte ConfigTransporte    @relation(fields: [configTransporteId], references: [id], onDelete: Cascade)
  reservas         ReservaTransporte[]

  @@index([configTransporteId, activo])
}

enum EstadoReservaTransporte {
  PENDIENTE
  CONFIRMADA
  CANCELADA
  RECHAZADA
  COMPLETADA
}

model ReservaTransporte {
  id               Int                     @id @default(autoincrement())
  codigo           String                  @unique
  rutaTransporteId Int
  clienteId        Int
  fechaViaje       DateTime
  asientos         Int                     @default(1)
  total            Decimal                 @db.Decimal(12, 2)
  estado           EstadoReservaTransporte @default(PENDIENTE)
  metodoPago       String                  @default("EFECTIVO")
  notasCliente     String?
  nombreContacto   String
  telefonoContacto String
  comision         Decimal?                @db.Decimal(10, 2)
  tasaComision     Decimal?                @db.Decimal(5, 4)
  montoDescuento   Decimal?                @db.Decimal(10, 2)
  codigoCupon      String?
  creadoAt         DateTime                @default(now())
  updatedAt        DateTime                @updatedAt

  ruta          RutaTransporte     @relation(fields: [rutaTransporteId], references: [id])
  cliente       Usuario            @relation("ReservasTransporteCliente", fields: [clienteId], references: [id])

  @@index([rutaTransporteId, estado])
  @@index([clienteId])
  @@index([fechaViaje])
}

// ─── REVIEWS ─────────────────────────────────────────────────

// ─── CUPONES DE VERTICALES DE SERVICIO ─────────────────────────
// Anexo B, Fase 4 (unificación núcleo-vs-verticales): reemplaza CuponHotel,
// CuponExpress, CuponTour, CuponTransporte (y sus *Uso) — 8 tablas casi
// idénticas — en un solo par polimórfico. El Cupon/CuponUso de Marketplace
// se deja intacto a propósito: tiene encima un sistema de analítica y
// detección de fraude (CuponRepository) exclusivo de ese módulo, sin nada
// equivalente que unificar en los verticales.
enum TipoEntidadCuponVertical {
  CONFIG_HOTEL
  CONFIG_EXPRESS
  CONFIG_TOUR
  CONFIG_TRANSPORTE
}

model CuponVertical {
  id              Int                      @id @default(autoincrement())
  codigo          String                   @unique
  tipoEntidad     TipoEntidadCuponVertical
  entidadId       Int?                     // null = aplica a todos los comercios de ese vertical (antes: configXId null)
  tipo            String                   @default("PORCENTAJE")
  valor           Decimal                  @db.Decimal(10, 2)
  minimoAplicable Decimal?                 @db.Decimal(12, 2) // reemplaza minimoNoches/minimoSubtotal/minimoPersonas/minimoAsientos
  usosMaximos     Int?
  usosActuales    Int                      @default(0)
  activo          Boolean                  @default(true)
  inicio          DateTime
  fin             DateTime
  createdAt       DateTime                 @default(now())

  usos CuponVerticalUso[]

  @@index([codigo, activo])
  @@index([activo, fin])
  @@index([tipoEntidad, entidadId])
}

model CuponVerticalUso {
  id          Int                      @id @default(autoincrement())
  cuponId     Int
  clienteId   Int
  tipoEntidad TipoEntidadCuponVertical // qué tipo de reserva/pedido consumió el cupón
  entidadId   Int                      // reservaHotelId/pedidoExpressId/reservaTourId/reservaTransporteId

  createdAt DateTime @default(now())

  cupon   CuponVertical @relation(fields: [cuponId], references: [id])
  cliente Usuario       @relation(fields: [clienteId], references: [id])

  @@unique([tipoEntidad, entidadId])
  @@index([cuponId, clienteId])
}

model TemporadaHotel {
  id               Int       @id @default(autoincrement())
  configHotelId    Int
  habitacionTipoId Int?
  nombre           String
  inicio           DateTime
  fin              DateTime
  precioPorNoche   Decimal   @db.Decimal(12, 2)
  activo           Boolean   @default(true)
  createdAt        DateTime  @default(now())

  configHotel    ConfigHotel     @relation(fields: [configHotelId], references: [id], onDelete: Cascade)
  habitacionTipo HabitacionTipo? @relation(fields: [habitacionTipoId], references: [id], onDelete: SetNull)

  @@index([configHotelId, activo])
  @@index([habitacionTipoId, activo])
  @@index([inicio, fin])
}

// ─── MÓDULO CULTURA ───────────────────────────────────────────
// Agenda cultural del territorio: fiestas y eventos por región/municipio,
// con boletería opcional. El evento sin entradas es puramente informativo
// (agenda/patrimonio); con entradas se vuelve transaccional y reutiliza la
// comisión y dispersión de la plataforma. Sigue el patrón del módulo Tour.

enum EstadoEventoCultural {
  BORRADOR
  PUBLICADO
  FINALIZADO
  CANCELADO
  POSPUESTO
}

enum EstadoReservaCultural {
  PENDIENTE
  CONFIRMADA
  CANCELADA
  RECHAZADA
  USADA
}

model EventoCultural {
  id             Int                  @id @default(autoincrement())
  comercioId     Int?
  titulo         String
  descripcion    String?
  categoria      String?
  departamento   String
  municipio      String
  lugar          String?
  latitud        Float?
  longitud       Float?
  fechaInicio    DateTime
  fechaFin       DateTime?
  portadaUrl     String?
  fotos          String[]
  videoUrl       String?
  patrimonio     Boolean              @default(false)
  patrimonioNota String?
  gratuito       Boolean              @default(true)
  destacado      Boolean              @default(false)
  estado         EstadoEventoCultural @default(BORRADOR)
  creadoAt       DateTime             @default(now())
  updatedAt      DateTime             @updatedAt

  comercio Comercio?         @relation("EventosCulturalesComercio", fields: [comercioId], references: [id])
  entradas EntradaCultural[]
  reservas ReservaCultural[]

  @@index([estado, fechaInicio])
  @@index([departamento, municipio])
  @@index([comercioId])
}

model EntradaCultural {
  id               Int      @id @default(autoincrement())
  eventoCulturalId Int
  nombre           String
  descripcion      String?
  precio           Decimal  @db.Decimal(12, 2)
  cupo             Int?
  vendidas         Int      @default(0)
  activa           Boolean  @default(true)
  orden            Int      @default(0)
  creadoAt         DateTime @default(now())
  updatedAt        DateTime @updatedAt

  evento   EventoCultural    @relation(fields: [eventoCulturalId], references: [id], onDelete: Cascade)
  reservas ReservaCultural[]

  @@index([eventoCulturalId, activa])
}

model ReservaCultural {
  id                Int                   @id @default(autoincrement())
  codigo            String                @unique
  eventoCulturalId  Int
  entradaCulturalId Int
  clienteId         Int
  cantidad          Int                   @default(1)
  total             Decimal               @db.Decimal(12, 2)
  estado            EstadoReservaCultural @default(PENDIENTE)
  metodoPago        String                @default("EFECTIVO")
  notasCliente      String?
  nombreContacto    String
  telefonoContacto  String
  comision          Decimal?              @db.Decimal(10, 2)
  tasaComision      Decimal?              @db.Decimal(5, 4)
  creadoAt          DateTime              @default(now())
  updatedAt         DateTime              @updatedAt

  evento  EventoCultural  @relation(fields: [eventoCulturalId], references: [id])
  entrada EntradaCultural @relation(fields: [entradaCulturalId], references: [id])
  cliente Usuario         @relation("ReservasCulturalesCliente", fields: [clienteId], references: [id])

  @@index([eventoCulturalId, estado])
  @@index([clienteId])
}

// ─── COMPARTE TU CHOCÓ (publicaciones comunitarias) ───────────
// Cualquier usuario autenticado publica foto(s)/video de un sitio turístico
// o historia cultural sin moderación previa. Control reactivo: cualquiera
// puede denunciar; un admin desestima la denuncia u oculta la publicación
// (no hay bloqueo de cuenta en este flujo).
model PublicacionCultural {
  id           Int      @id @default(autoincrement())
  autorId      Int
  titulo       String
  descripcion  String?
  fotoUrls     String[] @default([])
  videoUrl     String?
  departamento String
  municipio    String?
  activa       Boolean  @default(true)
  createdAt    DateTime @default(now())

  // Vitrina de comercio (v0): null = publicación personal "Comparte tu
  // Chocó" (comportamiento original, sin cambios); con valor = video de
  // negocio, listado aparte en /vitrina, nunca mezclado con el feed personal.
  comercioId            Int?
  moduloOrigen          String?
  videoPosterUrl        String?
  videoDuracionSegundos Int?
  videoPublicId         String?

  totalCompartidos Int @default(0)

  autor     Usuario                       @relation(fields: [autorId], references: [id])
  comercio  Comercio?                     @relation(fields: [comercioId], references: [id])
  denuncias DenunciaPublicacionCultural[]
  likes     LikePublicacionCultural[]
  vistas    VistaPublicacionCultural[]
  comentarios ComentarioPublicacionCultural[]

  @@index([activa, departamento, createdAt])
  @@index([comercioId, activa, createdAt])
}

// Seguir un comercio (cualquier vertical, no exclusivo de la Vitrina) — base
// para notificar novedades y para el ranking heurístico del feed (§3 del plan).
model SeguidorComercio {
  id         Int      @id @default(autoincrement())
  usuarioId  Int
  comercioId Int
  createdAt  DateTime @default(now())

  usuario  Usuario  @relation(fields: [usuarioId], references: [id], onDelete: Cascade)
  comercio Comercio @relation(fields: [comercioId], references: [id], onDelete: Cascade)

  @@unique([usuarioId, comercioId])
  @@index([comercioId])
}

model LikePublicacionCultural {
  id                     Int      @id @default(autoincrement())
  usuarioId              Int
  publicacionCulturalId  Int
  createdAt              DateTime @default(now())

  usuario     Usuario             @relation(fields: [usuarioId], references: [id])
  publicacion PublicacionCultural @relation(fields: [publicacionCulturalId], references: [id], onDelete: Cascade)

  @@unique([usuarioId, publicacionCulturalId])
  @@index([publicacionCulturalId])
}

enum MotivoDenunciaPublicacion {
  CONTENIDO_INAPROPIADO
  SPAM
  DERECHOS_DE_AUTOR
  NO_RELACIONADO
  OTRO
}

enum EstadoDenunciaPublicacion {
  PENDIENTE
  DESESTIMADA
  PUBLICACION_OCULTADA
}

model DenunciaPublicacionCultural {
  id                    Int                       @id @default(autoincrement())
  publicacionCulturalId Int
  denuncianteId         Int
  motivo                MotivoDenunciaPublicacion
  descripcion           String?
  estado                EstadoDenunciaPublicacion @default(PENDIENTE)
  revisadoPor           Int?
  revisadoAt            DateTime?
  notaRevision          String?
  createdAt             DateTime                  @default(now())

  publicacion PublicacionCultural @relation(fields: [publicacionCulturalId], references: [id], onDelete: Cascade)
  denunciante Usuario             @relation(fields: [denuncianteId], references: [id])

  @@unique([publicacionCulturalId, denuncianteId])
  @@index([estado, createdAt])
}

model VistaPublicacionCultural {
  id                    Int      @id @default(autoincrement())
  publicacionCulturalId Int
  usuarioId              Int?
  sesionId              String?
  duracionSegundos      Int?
  createdAt             DateTime @default(now())

  publicacion PublicacionCultural @relation(fields: [publicacionCulturalId], references: [id], onDelete: Cascade)
  usuario     Usuario?            @relation("VistasPublicacionUsuario", fields: [usuarioId], references: [id], onDelete: SetNull)

  @@index([publicacionCulturalId, createdAt])
  @@index([usuarioId, createdAt])
}

// ─── ALIANZAS COMERCIALES ─────────────────────────────────────
// Cupón compartido entre comercios de distintos módulos (Express, Hotel,
// Tour, Transporte, Pedido) para campañas conjuntas de turismo regional.
// Cada socio define su propio descuento y debe aceptar unirse voluntariamente;
// un admin aprueba la publicación antes de que el código sea válido en checkout.

model AlianzaComercial {
  id                  Int       @id @default(autoincrement())
  nombre              String
  descripcion         String?
  departamento        String?
  municipio           String?
  codigoCompartido    String    @unique
  estado              String    @default("PENDIENTE_APROBACION") // PENDIENTE_APROBACION | PUBLICADA | RECHAZADA | DESPUBLICADA
  inicio              DateTime
  fin                 DateTime
  creadoPorComercioId Int
  aprobadoPor         Int?
  aprobadoAt          DateTime?
  motivoRechazo       String?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  socios AlianzaSocio[]

  @@index([codigoCompartido, estado])
  @@index([departamento, municipio])
}

model AlianzaSocio {
  id             Int       @id @default(autoincrement())
  alianzaId      Int
  comercioId     Int
  modulo         String    // "PEDIDO" | "EXPRESS" | "HOTEL" | "TOUR" | "TRANSPORTE"
  tipoDescuento  String    @default("PORCENTAJE") // "PORCENTAJE" | "VALOR_FIJO"
  valorDescuento Decimal   @db.Decimal(10, 2)
  aceptado       Boolean   @default(false)
  aceptadoAt     DateTime?
  activo         Boolean   @default(true) // false = el socio se retiró (ver regla de buena fe en alianza.service.js)
  createdAt      DateTime  @default(now())

  alianza  AlianzaComercial @relation(fields: [alianzaId], references: [id], onDelete: Cascade)
  comercio Comercio         @relation(fields: [comercioId], references: [id])

  @@unique([alianzaId, comercioId, modulo])
  @@index([comercioId, modulo, aceptado, activo])
}

model ComentarioPublicacionCultural {
  id                    Int      @id @default(autoincrement())
  publicacionCulturalId Int
  usuarioId             Int
  texto                 String
  createdAt             DateTime @default(now())

  publicacion           PublicacionCultural @relation(fields: [publicacionCulturalId], references: [id], onDelete: Cascade)
  usuario               Usuario             @relation(fields: [usuarioId], references: [id])

  @@index([publicacionCulturalId, createdAt])
}
