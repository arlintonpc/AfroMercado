generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── ENUMS ────────────────────────────────────────────────────

enum Rol {
  COMPRADOR
  COMERCIANTE
  REPARTIDOR
  ADMIN
}

enum UnidadVenta {
  KG
  UNIDAD
  LITRO
  PAQUETE
  DOCENA
  MANOJO
}

enum AlcanceVenta {
  LOCAL
  NACIONAL
  AMBOS
}

enum EstadoPedido {
  PENDIENTE_PAGO
  VERIFICANDO_PAGO
  PAGO_FALLIDO
  CONFIRMADO
  CANCELADO
  EXPIRADO
  ENTREGADO
}

enum EstadoSubPedido {
  CONFIRMADO
  EN_PREPARACION
  LISTO
  EN_CAMINO
  ENTREGADO
  CANCELADO
}

enum EstadoPago {
  PENDIENTE
  VERIFICANDO
  CONFIRMADO
  FALLIDO
  REEMBOLSADO
}

enum TipoOferta {
  PORCENTAJE
  VALOR_FIJO
}

enum MetodoPago {
  NEQUI
  DAVIPLATA
  TRANSFERENCIA
  EFECTIVO
}

enum EstadoEntrega {
  ASIGNADA
  RECOGIDA
  EN_CAMINO
  ENTREGADA
  FALLIDA
}

enum TipoDocumento {
  CC
  TI
  CE
  PEP
  PASAPORTE
  NIT
}

enum TipoVehiculo {
  MOTO
  BICICLETA
  CARRO
  CAMIONETA
  TRICIMOTO
}

enum EstadoSolicitudRepartidor {
  PENDIENTE
  APROBADA
  RECHAZADA
}

enum EstadoComerciante {
  PENDIENTE_REVISION
  APROBADO
  RECHAZADO
  SUSPENDIDO
}

enum TipoLiquidacion {
  COMERCIANTE
  REPARTIDOR
}

enum EstadoLiquidacion {
  PENDIENTE
  PAGADA
  CANCELADA
}

// ─── MODELOS ──────────────────────────────────────────────────

model Usuario {
  id           Int       @id @default(autoincrement())
  nombre       String
  email        String    @unique
  telefono     String?
  avatarUrl    String?
  passwordHash String
  rol          Rol       @default(COMPRADOR)
  activo       Boolean   @default(true)
  motivoBloqueo String?
  bloqueadoPor  Int?
  bloqueadoAt   DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  deletedAt    DateTime?

  municipio          String?
  tipoDocumento      TipoDocumento?
  numeroDocumento    String?
  autorizacionDatos  Boolean   @default(false)
  autorizacionFecha  DateTime?
  passwordCambiadoAt DateTime?
  tokensRecuperacion TokenRecuperacion[]
  sesionesReset      SesionReset[]

  comercio                 Comercio?
  solicitudRepartidor      SolicitudRepartidor?
  pedidos                  Pedido[]
  direcciones          Direccion[]
  carrito              CarritoItem[]
  reviews              Review[]
  reviewsProducto      ReviewProducto[]
  visibilidadesAdmin   VisibilidadPagada[] @relation("VisibilidadAdmin")
  campanasAdmin        CampanaHero[]       @relation("CampanaAdmin")
  notificaciones       Notificacion[]
  favoritos            Favorito[]
  busquedasHistorial   BusquedaHistorial[]
  vistasProducto       VistaProducto[]
  cuponUsos            CuponUso[]
  cuponAsignaciones    CuponAsignacion[]
  conversaciones            Conversacion[]      @relation("ConversacionComprador")
  mensajes                  Mensaje[]
  entregas                  Entrega[]           @relation("EntregaRepartidor")
  pushSubscripciones        PushSubscripcion[]
  liquidacionesBeneficiario Liquidacion[]       @relation("LiquidacionBeneficiario")
  liquidacionesCreadas      Liquidacion[]       @relation("LiquidacionAdmin")
  liquidacionesPagadas      Liquidacion[]       @relation("LiquidacionPagador")
}

model Comercio {
  id           Int       @id @default(autoincrement())
  usuarioId    Int       @unique
  nombre       String
  municipio    String
  descripcion  String?
  historia     String?
  whatsapp     String?
  logoUrl      String?
  videoUrl     String?
  videoPosterUrl String?
  videoPublicId String?
  videoDuracionSegundos Float?
  videoDuracionOriginalSegundos Float?
  videoRecorteInicioSegundos Float?
  videoRecorteFinSegundos Float?
  videoAncho   Int?
  videoAlto    Int?
  videoBytes   Int?
  videoFormato String?
  videoMimeType String?
  calificacion Decimal   @default(0) @db.Decimal(3, 2)
  totalReviews Int       @default(0)
  totalVentas  Int       @default(0)
  verificado        Boolean           @default(false)
  estadoRegistro    EstadoComerciante @default(PENDIENTE_REVISION)
  motivoRechazo     String?
  revisadoPor       Int?
  revisadoAt        DateTime?
  whatsappVisible   Boolean           @default(false)
  whatsappAprobadoPor Int?
  whatsappAprobadoAt  DateTime?
  vereda            String?
  fotoDocumentoUrl  String?
  activo            Boolean           @default(true)
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt
  deletedAt         DateTime?

  usuario           Usuario             @relation(fields: [usuarioId], references: [id])
  productos         Producto[]
  subPedidos        SubPedido[]
  reviews           Review[]
  visibilidades     VisibilidadPagada[]
  vistasProductos   VistaProducto[]
  conversaciones    Conversacion[]
  cuponComercio     CuponComercio[]
  comisiones        ComisionComercio[]
}

model Categoria {
  id       Int       @id @default(autoincrement())
  nombre   String    @unique
  slug     String    @unique
  icono    String?
  activa   Boolean   @default(true)

  productos Producto[]
}

model Producto {
  id                  Int          @id @default(autoincrement())
  comercioId          Int
  categoriaId         Int?
  nombre              String
  descripcion         String?
  precio              Decimal      @db.Decimal(12, 2)
  unidad              UnidadVenta
  stock               Int          @default(0)
  stockReservado      Int          @default(0)
  fotoUrl             String?
  imagenes            String[]     @default([])
  videoUrl            String?
  videoPosterUrl      String?
  videoPublicId       String?
  videoDuracionSegundos Float?
  videoDuracionOriginalSegundos Float?
  videoRecorteInicioSegundos Float?
  videoRecorteFinSegundos Float?
  videoAncho          Int?
  videoAlto           Int?
  videoBytes          Int?
  videoFormato        String?
  videoMimeType       String?
  activo              Boolean      @default(true)
  diasAlistamientoMin Int          @default(1)
  diasAlistamientoMax Int          @default(3)
  alcance             AlcanceVenta @default(LOCAL)
  pesoKg              Decimal?     @db.Decimal(6, 2)
  createdAt           DateTime     @default(now())
  updatedAt           DateTime     @updatedAt
  deletedAt           DateTime?

  comercio         Comercio           @relation(fields: [comercioId], references: [id])
  categoria        Categoria?         @relation(fields: [categoriaId], references: [id])
  carrito          CarritoItem[]
  pedidoItems      PedidoItem[]
  historialPrecios PrecioHistorial[]
  reviews          ReviewProducto[]
  visibilidades    VisibilidadPagada[]
  ofertas          Oferta[]
  vistas           VistaProducto[]
  favoritos        Favorito[]

  @@index([comercioId, activo])
  @@index([categoriaId, activo])
  @@index([alcance, activo])
}

model PrecioHistorial {
  id          Int      @id @default(autoincrement())
  productoId  Int
  precio      Decimal  @db.Decimal(12, 2)
  cambiadoPor Int
  createdAt   DateTime @default(now())

  producto Producto @relation(fields: [productoId], references: [id])
}

model Direccion {
  id           Int       @id @default(autoincrement())
  usuarioId    Int
  alias        String
  linea1       String
  barrio       String?
  municipio    String
  departamento String
  referencia   String?
  telefono     String?
  esPrincipal  Boolean   @default(false)
  deletedAt    DateTime?

  usuario Usuario  @relation(fields: [usuarioId], references: [id])
  pedidos Pedido[]
}

model CarritoItem {
  id              Int      @id @default(autoincrement())
  usuarioId       Int
  productoId      Int
  cantidad        Int
  precioAlAgregar Decimal  @db.Decimal(12, 2)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  usuario  Usuario  @relation(fields: [usuarioId], references: [id])
  producto Producto @relation(fields: [productoId], references: [id])

  @@unique([usuarioId, productoId])
}

model Pedido {
  id             Int          @id @default(autoincrement())
  compradorId    Int
  direccionId    Int?
  direccionTexto String
  estado         EstadoPedido @default(PENDIENTE_PAGO)
  subtotal       Decimal      @db.Decimal(12, 2)
  comisionTotal  Decimal      @db.Decimal(12, 2)
  total          Decimal      @db.Decimal(12, 2)
  costoEnvio     Decimal      @default(0) @db.Decimal(10, 2)
  notas          String?
  expiresAt      DateTime
  codigo         String?      @unique
  deletedAt      DateTime?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  cuponId        Int?
  cuponDescuento Decimal? @db.Decimal(12, 2)

  comprador  Usuario    @relation(fields: [compradorId], references: [id])
  direccion  Direccion? @relation(fields: [direccionId], references: [id])
  subPedidos SubPedido[]
  pagos      Pago[]
  cuponUso   CuponUso?
  cupon      Cupon?     @relation(fields: [cuponId], references: [id], onDelete: SetNull)

  @@index([compradorId])
}

model SubPedido {
  id                   Int             @id @default(autoincrement())
  pedidoId             Int
  comercioId           Int
  estado               EstadoSubPedido @default(CONFIRMADO)
  subtotal             Decimal         @db.Decimal(12, 2)
  comision             Decimal         @db.Decimal(12, 2)
  tasaComisionAplicada Decimal?        @db.Decimal(5, 4)
  neto                 Decimal         @db.Decimal(12, 2)
  notas                String?
  createdAt            DateTime        @default(now())
  updatedAt            DateTime        @updatedAt

  pedido   Pedido       @relation(fields: [pedidoId], references: [id])
  comercio Comercio     @relation(fields: [comercioId], references: [id])
  items    PedidoItem[]
  entrega  Entrega?

  @@index([comercioId])
  @@index([pedidoId])
}

model PedidoItem {
  id             Int     @id @default(autoincrement())
  subPedidoId    Int
  productoId     Int
  ofertaId       Int?
  cantidad       Int
  precioUnitario Decimal @db.Decimal(12, 2)
  subtotal       Decimal @db.Decimal(12, 2)

  subPedido SubPedido @relation(fields: [subPedidoId], references: [id])
  producto  Producto  @relation(fields: [productoId], references: [id])
  oferta    Oferta?   @relation(fields: [ofertaId], references: [id], onDelete: SetNull)

  @@index([ofertaId])
}

model Pago {
  id             Int        @id @default(autoincrement())
  pedidoId       Int
  monto          Decimal    @db.Decimal(12, 2)
  metodo         MetodoPago
  estado         EstadoPago @default(PENDIENTE)
  referencia     String?
  comprobanteUrl String?
  idempotencyKey String     @unique
  verificadoPor  Int?
  verificadoAt   DateTime?
  notas          String?
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt

  pedido Pedido @relation(fields: [pedidoId], references: [id])

  @@index([pedidoId])
}

model Entrega {
  id           Int           @id @default(autoincrement())
  subPedidoId  Int           @unique
  repartidorId Int?
  estado       EstadoEntrega @default(ASIGNADA)
  direccion    String
  notas        String?
  pagoRepartidor Decimal?     @db.Decimal(10, 2)
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  subPedido  SubPedido @relation(fields: [subPedidoId], references: [id])
  repartidor Usuario?  @relation("EntregaRepartidor", fields: [repartidorId], references: [id])

  @@index([repartidorId])
}

model Review {
  id           Int      @id @default(autoincrement())
  comercioId   Int
  compradorId  Int
  pedidoId     Int      @unique
  calificacion Int
  comentario   String?
  createdAt    DateTime @default(now())

  comercio  Comercio @relation(fields: [comercioId], references: [id])
  comprador Usuario  @relation(fields: [compradorId], references: [id])
}

model TokenRecuperacion {
  id            Int       @id @default(autoincrement())
  usuarioId     Int
  codigoHash    String
  intentos      Int       @default(0)
  expiresAt     DateTime
  usadoEn       DateTime?
  reemplazadoEn DateTime?
  createdAt     DateTime  @default(now())

  usuario Usuario @relation(fields: [usuarioId], references: [id])

  @@index([usuarioId])
}

model SesionReset {
  id        Int       @id @default(autoincrement())
  usuarioId Int
  tokenHash String
  expiresAt DateTime
  usadoEn   DateTime?
  createdAt DateTime  @default(now())

  usuario Usuario @relation(fields: [usuarioId], references: [id])

  @@index([usuarioId])
}

model ReviewProducto {
  id           Int      @id @default(autoincrement())
  productoId   Int
  compradorId  Int
  calificacion Int
  comentario   String?
  createdAt    DateTime @default(now())

  producto  Producto @relation(fields: [productoId], references: [id])
  comprador Usuario  @relation(fields: [compradorId], references: [id])

  @@unique([compradorId, productoId])
  @@index([productoId])
}

model Config {
  clave     String   @id
  valor     String
  updatedAt DateTime @updatedAt
}

model Oferta {
  id          Int        @id @default(autoincrement())
  productoId  Int
  tipo        TipoOferta
  valor       Decimal    @db.Decimal(10,2)
  etiqueta    String?
  inicio      DateTime
  fin         DateTime
  activa      Boolean    @default(true)
  stockLimite Int?
  stockUsado  Int        @default(0)
  createdAt   DateTime   @default(now())

  producto    Producto     @relation(fields: [productoId], references: [id])
  pedidoItems PedidoItem[]

  @@index([productoId, activa, fin])
  @@index([activa, fin])
}

model VistaProducto {
  id         Int      @id @default(autoincrement())
  productoId Int
  comercioId Int
  usuarioId  Int?
  sesionId   String?
  createdAt  DateTime @default(now())

  producto Producto @relation(fields: [productoId], references: [id])
  comercio Comercio @relation(fields: [comercioId], references: [id])
  usuario  Usuario? @relation(fields: [usuarioId], references: [id])

  @@index([productoId, createdAt])
  @@index([comercioId, createdAt])
  @@index([usuarioId, createdAt])
}

model Notificacion {
  id        Int      @id @default(autoincrement())
  usuarioId Int
  tipo      String
  titulo    String
  mensaje   String
  leida     Boolean  @default(false)
  url       String?
  datos     Json?
  createdAt DateTime @default(now())

  usuario Usuario @relation(fields: [usuarioId], references: [id])

  @@index([usuarioId, leida, createdAt])
}

model Favorito {
  id         Int      @id @default(autoincrement())
  usuarioId  Int
  productoId Int
  createdAt  DateTime @default(now())

  usuario  Usuario  @relation(fields: [usuarioId], references: [id])
  producto Producto @relation(fields: [productoId], references: [id])

  @@unique([usuarioId, productoId])
  @@index([usuarioId, createdAt])
}

model BusquedaHistorial {
  id        Int      @id @default(autoincrement())
  usuarioId Int?
  sesionId  String?
  query     String
  createdAt DateTime @default(now())

  usuario Usuario? @relation(fields: [usuarioId], references: [id])

  @@index([usuarioId, createdAt])
  @@index([sesionId, createdAt])
}

model CampanaHero {
  id          Int      @id @default(autoincrement())
  tipo        String   @default("PUBLICIDAD")
  titulo      String
  subtitulo   String?
  imagenUrl   String
  ctaTexto    String   @default("Ver más")
  urlDestino  String
  activa      Boolean  @default(true)
  prioridad   Int      @default(0)
  inicio      DateTime
  fin         DateTime
  montoCOP    Decimal? @db.Decimal(10, 2)
  notas       String?
  vistas      Int      @default(0)
  clics       Int      @default(0)
  creadoPor   Int
  createdAt   DateTime @default(now())

  admin Usuario @relation("CampanaAdmin", fields: [creadoPor], references: [id])

  @@index([activa, fin])
}

// ─── FASE 2 ───────────────────────────────────────────────────

enum TipoDistribucionCupon {
  PUBLICO   // cualquiera que tenga el código puede usarlo
  ASIGNADO  // solo usuarios en CuponAsignacion pueden usarlo
}

model Cupon {
  id                    Int                    @id @default(autoincrement())
  codigo                String                 @unique
  tipo                  TipoOferta
  valor                 Decimal                @db.Decimal(10, 2)
  minimoCompra          Decimal?               @db.Decimal(12, 2)
  usosMaximos           Int?                   // tope global de redenciones
  usosMaximosPorUsuario Int?                   // tope por persona (null = ilimitado)
  usosActuales          Int                    @default(0)
  activo                Boolean                @default(true)
  inicio                DateTime
  fin                   DateTime
  soloNuevos            Boolean                @default(false)
  distribucion          TipoDistribucionCupon  @default(PUBLICO)
  createdAt             DateTime               @default(now())

  pedidos      Pedido[]
  usos         CuponUso[]
  comercios    CuponComercio[]
  asignaciones CuponAsignacion[]

  @@index([codigo, activo])
  @@index([activo, fin])
}

model CuponUso {
  id        Int      @id @default(autoincrement())
  cuponId   Int
  usuarioId Int
  pedidoId  Int      @unique
  createdAt DateTime @default(now())

  cupon   Cupon   @relation(fields: [cuponId], references: [id])
  usuario Usuario @relation(fields: [usuarioId], references: [id])
  pedido  Pedido  @relation(fields: [pedidoId], references: [id])

  @@index([cuponId, usuarioId])
}

model CuponComercio {
  id         Int @id @default(autoincrement())
  cuponId    Int
  comercioId Int

  cupon    Cupon    @relation(fields: [cuponId], references: [id], onDelete: Cascade)
  comercio Comercio @relation(fields: [comercioId], references: [id], onDelete: Cascade)

  @@unique([cuponId, comercioId])
  @@index([cuponId])
}

model CuponAsignacion {
  id        Int      @id @default(autoincrement())
  cuponId   Int
  usuarioId Int
  createdAt DateTime @default(now())

  cupon   Cupon   @relation(fields: [cuponId], references: [id], onDelete: Cascade)
  usuario Usuario @relation(fields: [usuarioId], references: [id], onDelete: Cascade)

  @@unique([cuponId, usuarioId])
  @@index([cuponId])
}

model Conversacion {
  id           Int       @id @default(autoincrement())
  compradorId  Int
  comercioId   Int
  ultimoMensAt DateTime?
  createdAt    DateTime  @default(now())

  comprador Usuario  @relation("ConversacionComprador", fields: [compradorId], references: [id])
  comercio  Comercio @relation(fields: [comercioId], references: [id])
  mensajes  Mensaje[]

  @@unique([compradorId, comercioId])
  @@index([compradorId, ultimoMensAt])
  @@index([comercioId, ultimoMensAt])
}

model Mensaje {
  id             Int      @id @default(autoincrement())
  conversacionId Int
  autorId        Int
  contenido      String
  leido          Boolean  @default(false)
  createdAt      DateTime @default(now())

  conversacion Conversacion @relation(fields: [conversacionId], references: [id])
  autor        Usuario      @relation(fields: [autorId], references: [id])

  @@index([conversacionId, createdAt])
  @@index([conversacionId, id])
  @@index([autorId])
}

model SolicitudRepartidor {
  id               Int                       @id @default(autoincrement())
  usuarioId        Int                       @unique
  vehiculoTipo     TipoVehiculo
  vehiculoMarca    String
  vehiculoModelo   String
  vehiculoColor    String
  vehiculoPlaca    String
  vehiculoAnio     Int
  licenciaNumero   String
  fotoVehiculoUrl  String?
  fotoLicenciaUrl  String?
  municipioBase    String                    @default("")
  municipiosExtra  String[]
  estado           EstadoSolicitudRepartidor @default(PENDIENTE)
  notasAdmin       String?
  revisadoPor      Int?
  revisadoAt       DateTime?
  createdAt        DateTime                  @default(now())
  updatedAt        DateTime                  @updatedAt

  usuario Usuario @relation(fields: [usuarioId], references: [id])

  @@index([estado, createdAt])
}

model TarifaEnvio {
  id           Int     @id @default(autoincrement())
  departamento String
  pesoMaxKg    Decimal @db.Decimal(6, 2)
  precio       Decimal @db.Decimal(10, 2)
  activa       Boolean @default(true)

  @@unique([departamento, pesoMaxKg])
  @@index([departamento, activa])
}

// ──────────────────────────────────────────────────────────────

model VisibilidadPagada {
  id         Int      @id @default(autoincrement())
  comercioId Int
  productoId Int?
  tipo       String   // "CATALOGO" | "HOME_DESTACADO"
  activa     Boolean  @default(true)
  inicio     DateTime
  fin        DateTime
  montoCOP   Decimal  @db.Decimal(10, 2)
  notas      String?
  creadoPor  Int
  vistas     Int      @default(0)
  etiqueta   String?
  createdAt  DateTime @default(now())

  comercio Comercio  @relation(fields: [comercioId], references: [id])
  producto Producto? @relation(fields: [productoId], references: [id])
  admin    Usuario   @relation("VisibilidadAdmin", fields: [creadoPor], references: [id])

  @@index([tipo, activa, fin])
  @@index([comercioId])
}

model PushSubscripcion {
  id        Int      @id @default(autoincrement())
  usuarioId Int
  endpoint  String   @unique
  p256dh    String
  auth      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  usuario   Usuario  @relation(fields: [usuarioId], references: [id], onDelete: Cascade)

  @@index([usuarioId])
}

model ComisionComercio {
  id         Int       @id @default(autoincrement())
  comercioId Int
  tasa       Decimal   @db.Decimal(5, 4)
  motivo     String?
  desde      DateTime  @default(now())
  hasta      DateTime?
  creadoPor  Int
  createdAt  DateTime  @default(now())

  comercio Comercio @relation(fields: [comercioId], references: [id])

  @@index([comercioId, hasta])
}

model AccionModeracion {
  id         Int      @id @default(autoincrement())
  adminId    Int
  targetId   Int
  targetTipo String
  accion     String
  motivo     String?
  createdAt  DateTime @default(now())

  @@index([targetId, targetTipo, createdAt])
}

model Liquidacion {
  id             Int               @id @default(autoincrement())
  tipo           TipoLiquidacion
  beneficiarioId Int
  monto          Decimal           @db.Decimal(10, 2)
  estado         EstadoLiquidacion @default(PENDIENTE)
  periodoDesde   DateTime
  periodoHasta   DateTime
  cuentaDestino  String?
  comprobante    String?
  notas          String?
  creadoPor      Int
  pagadoPor      Int?
  pagadoAt       DateTime?
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt

  beneficiario    Usuario   @relation("LiquidacionBeneficiario", fields: [beneficiarioId], references: [id])
  adminCreador    Usuario   @relation("LiquidacionAdmin", fields: [creadoPor], references: [id])
  adminPagador    Usuario?  @relation("LiquidacionPagador", fields: [pagadoPor], references: [id])

  @@index([beneficiarioId, estado])
  @@index([tipo, estado, createdAt])
}
