// ============================================================
//  Módulo Empleo / Bolsa de Trabajo comunitario (Fase 6)
//  Cualquier Usuario puede publicar una oferta (no solo Comercio — el
//  espíritu "comunitario" incluye a quien no tiene un negocio formal) y
//  cualquier Usuario puede postularse (el rol regula permisos de otros
//  módulos, no es una identidad excluyente de "quien busca trabajo").
//  Moderación ligera antes de publicar, dado el contexto de comunidades
//  vulnerables. La hoja de vida se snapshotea en cada postulación (mismo
//  espíritu que Disputa.montoOriginal) para que el postulante no pueda
//  "editar retroactivamente" lo que un empleador ya vio.
// ============================================================
enum EstadoOfertaEmpleo {
  BORRADOR
  PUBLICADA
  PAUSADA
  CERRADA
}

enum TipoContratoEmpleo {
  TIEMPO_COMPLETO
  MEDIO_TIEMPO
  POR_DIAS
  TEMPORAL
  OTRO
}

enum EstadoPostulacionEmpleo {
  ENVIADA
  VISTA
  PRESELECCIONADO
  RECHAZADA
  CONTRATADO
  RETIRADA
}

model OfertaEmpleo {
  id                Int                @id @default(autoincrement())
  publicadoPorId    Int
  comercioId        Int?
  titulo            String
  descripcion       String
  categoria         String?
  tipoContrato      TipoContratoEmpleo
  municipio         String
  departamento      String?
  salarioMin        Decimal?           @db.Decimal(12, 2)
  salarioMax        Decimal?           @db.Decimal(12, 2)
  salarioNegociable Boolean            @default(false)
  requisitos        String?
  vacantes          Int                @default(1)
  estado            EstadoOfertaEmpleo @default(BORRADOR)
  estadoModeracion  String             @default("PENDIENTE") // PENDIENTE | APROBADA | RECHAZADA
  revisadoPor       Int?
  revisadoAt        DateTime?
  motivoRechazoModeracion String?
  fechaCierre       DateTime?
  contactoWhatsapp  String?
  imagenUrl         String?
  preguntas         Json               @default("[]") // [{id, texto, tipo: TEXTO|SI_NO|OPCION_MULTIPLE, opciones?}]
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  deletedAt         DateTime?

  publicadoPor  Usuario             @relation("OfertasEmpleoPublicadas", fields: [publicadoPorId], references: [id])
  comercio      Comercio?           @relation(fields: [comercioId], references: [id])
  postulaciones PostulacionEmpleo[]
  favoritos     FavoritoOfertaEmpleo[]
  denuncias     DenunciaOfertaEmpleo[]

  @@index([estado, estadoModeracion, municipio, createdAt])
  @@index([publicadoPorId])
  @@index([comercioId])
}

model FavoritoOfertaEmpleo {
  id             Int      @id @default(autoincrement())
  usuarioId      Int
  ofertaEmpleoId Int
  createdAt      DateTime @default(now())

  usuario Usuario      @relation(fields: [usuarioId], references: [id], onDelete: Cascade)
  oferta  OfertaEmpleo @relation(fields: [ofertaEmpleoId], references: [id], onDelete: Cascade)

  @@unique([usuarioId, ofertaEmpleoId])
  @@index([usuarioId])
  @@index([ofertaEmpleoId])
}

// Denuncias de ofertas de empleo (falsas, explotación laboral, discriminatorias,
// estafa, etc.). El admin puede desestimar, bloquear solo la oferta denunciada,
// o bloquear la cuenta completa del publicador — en ese último caso TODAS sus
// demás ofertas activas se cierran también (ver EmpleoService.resolverDenuncia).
enum MotivoDenunciaEmpleo {
  OFERTA_FALSA
  EXPLOTACION_LABORAL
  DISCRIMINATORIA
  ESTAFA_DINERO
  CONTENIDO_INAPROPIADO
  OTRO
}

enum EstadoDenunciaEmpleo {
  PENDIENTE
  DESESTIMADA
  OFERTA_BLOQUEADA
  CUENTA_BLOQUEADA
}

model DenunciaOfertaEmpleo {
  id             Int                  @id @default(autoincrement())
  ofertaEmpleoId Int
  denuncianteId  Int
  motivo         MotivoDenunciaEmpleo
  descripcion    String?
  estado         EstadoDenunciaEmpleo @default(PENDIENTE)
  revisadoPor    Int?
  revisadoAt     DateTime?
  notaRevision   String?
  createdAt      DateTime             @default(now())

  oferta      OfertaEmpleo @relation(fields: [ofertaEmpleoId], references: [id], onDelete: Cascade)
  denunciante Usuario      @relation(fields: [denuncianteId], references: [id])

  @@unique([ofertaEmpleoId, denuncianteId])
  @@index([estado, createdAt])
}

model HojaDeVida {
  id               Int      @id @default(autoincrement())
  usuarioId        Int      @unique
  resumenPerfil    String?
  telefonoContacto String
  experiencia      Json     // [{empresa, cargo, desde, hasta, descripcion}]
  educacion        Json     // [{institucion, titulo, nivel, anio}]
  habilidades      String[] @default([])
  disponibilidad   String?
  cvUrl            String?  // PDF adjunto por el usuario (opcional, complementa el formulario)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  usuario Usuario @relation(fields: [usuarioId], references: [id])
}

model PostulacionEmpleo {
  id              Int                     @id @default(autoincrement())
  ofertaEmpleoId  Int
  postulanteId    Int
  hojaDeVidaId    Int
  // Snapshot de la hoja de vida al momento de postular (no solo la FK) —
  // evita que el candidato la edite después de que el empleador ya la vio.
  experienciaSnap Json
  educacionSnap   Json
  habilidadesSnap String[]                @default([])
  resumenPerfilSnap String?               // HojaDeVida.resumenPerfil al momento de postular
  disponibilidadSnap String?              // HojaDeVida.disponibilidad al momento de postular
  fotoSnapUrl     String?                 // Usuario.avatarUrl al momento de postular
  cvSnapUrl       String?                 // HojaDeVida.cvUrl al momento de postular
  respuestas      Json                    @default("[]") // [{preguntaId, texto, respuesta}]
  mensaje         String?
  estado          EstadoPostulacionEmpleo @default(ENVIADA)
  vistaAt         DateTime?
  notasPublicador String?
  createdAt       DateTime                @default(now())
  updatedAt       DateTime                @updatedAt

  oferta     OfertaEmpleo @relation(fields: [ofertaEmpleoId], references: [id])
  postulante Usuario      @relation("PostulacionesEmpleoEnviadas", fields: [postulanteId], references: [id])

  @@unique([ofertaEmpleoId, postulanteId])
  @@index([ofertaEmpleoId, estado])
  @@index([postulanteId])
}

model CampanaHero {
  id          Int      @id @default(autoincrement())
  tipo        String   @default("PUBLICIDAD")
  titulo      String
  subtitulo   String?
