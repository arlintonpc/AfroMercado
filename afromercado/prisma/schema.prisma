generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── ENUMS ────────────────────────────────────────────────────

enum Rol {
  COMPRADOR
  COMERCIANTE
  REPARTIDOR
  ADMIN
}

enum UnidadVenta {
  KG
  UNIDAD
  LITRO
  PAQUETE
  DOCENA
  MANOJO
}

enum AlcanceVenta {
  LOCAL
  NACIONAL
  AMBOS
}

enum EstadoPedido {
  PENDIENTE_PAGO
  VERIFICANDO_PAGO
  PAGO_FALLIDO
  CONFIRMADO
  CANCELADO
  EXPIRADO
  ENTREGADO
}

enum EstadoSubPedido {
  CONFIRMADO
  EN_PREPARACION
  LISTO
  EN_CAMINO
  ENTREGADO
  CANCELADO
}

enum EstadoPago {
  PENDIENTE
  VERIFICANDO
  CONFIRMADO
  FALLIDO
  REEMBOLSADO
}

enum TipoOferta {
  PORCENTAJE
  VALOR_FIJO
}

enum MetodoPago {
  NEQUI
  DAVIPLATA
  TRANSFERENCIA
  EFECTIVO
  PASARELA
}

enum EstadoEntrega {
  ASIGNADA
  RECOGIDA
  EN_CAMINO
  ENTREGADA
  FALLIDA
}

enum TipoDocumento {
  CC
  TI
  CE
  PEP
  PASAPORTE
  NIT
}

enum TipoVehiculo {
  MOTO
  BICICLETA
  CARRO
  CAMIONETA
  TRICIMOTO
}

enum EstadoSolicitudRepartidor {
  PENDIENTE
  APROBADA
  RECHAZADA
}

enum EstadoComerciante {
  PENDIENTE_REVISION
  APROBADO
  RECHAZADO
  SUSPENDIDO
}

enum TipoLiquidacion {
  COMERCIANTE
  REPARTIDOR
}

enum EstadoLiquidacion {
  PENDIENTE
  PAGADA
  CANCELADA
}

enum ProveedorPago {
  SANDBOX
  WOMPI
  PAYU
  EPAYCO
  MERCADOPAGO
}

enum TipoCuentaDispersion {
  AHORROS
  CORRIENTE
  BILLETERA_DIGITAL
}

enum EstadoCuentaDispersion {
  PENDIENTE_VERIFICACION
  VERIFICADA
  RECHAZADA
  SUSPENDIDA
}

enum EstadoDispersionPago {
  PENDIENTE
  PROGRAMADA
  ENVIADA
  CONFIRMADA
  FALLIDA
  CANCELADA
  REVERTIDA
}

// ─── MODELOS ──────────────────────────────────────────────────

model Usuario {
  id           Int       @id @default(autoincrement())
  nombre       String
  email        String    @unique
  telefono     String?
  avatarUrl    String?
  passwordHash String
  rol          Rol       @default(COMPRADOR)
  activo       Boolean   @default(true)
  motivoBloqueo String?
  bloqueadoPor  Int?
  bloqueadoAt   DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  deletedAt    DateTime?

  municipio          String?
  departamento       String?
  tipoDocumento      TipoDocumento?
  numeroDocumento    String?
  autorizacionDatos  Boolean   @default(false)
  autorizacionFecha  DateTime?
  passwordCambiadoAt DateTime?
  tokensRecuperacion TokenRecuperacion[]
  sesionesReset      SesionReset[]

  comercio                 Comercio?
  solicitudRepartidor      SolicitudRepartidor?
  pedidos                  Pedido[]
  direcciones          Direccion[]
  carrito              CarritoItem[]
  reviews              Review[]
  reviewsProducto      ReviewProducto[]
  visibilidadesAdmin   VisibilidadPagada[] @relation("VisibilidadAdmin")
  campanasAdmin        CampanaHero[]       @relation("CampanaAdmin")
  solicitudesPublicidadRevisadas SolicitudPublicidad[] @relation("SolicitudPublicidadRevisor")
  notificaciones       Notificacion[]
  favoritos            Favorito[]
  busquedasHistorial   BusquedaHistorial[]
  vistasProducto       VistaProducto[]
  cuponUsos            CuponUso[]
  cuponAsignaciones    CuponAsignacion[]
  favoritosHotel       FavoritoHotel[]
  conversaciones            Conversacion[]      @relation("ConversacionComprador")
  mensajes                  Mensaje[]
  entregas                  Entrega[]           @relation("EntregaRepartidor")
  pushSubscripciones        PushSubscripcion[]
  liquidacionesBeneficiario Liquidacion[]       @relation("LiquidacionBeneficiario")
  liquidacionesCreadas      Liquidacion[]       @relation("LiquidacionAdmin")
  liquidacionesPagadas      Liquidacion[]       @relation("LiquidacionPagador")
  pedidosExpressCliente     PedidoExpress[]     @relation("PedidosExpressCliente")
  pedidosExpressRepartidor  PedidoExpress[]     @relation("PedidosExpressRepartidor")
  reservasHotel             ReservaHotel[]      @relation("ReservasHotelCliente")
  reservasTour              ReservaTour[]       @relation("ReservasTourCliente")
  reservasTransporte        ReservaTransporte[] @relation("ReservasTransporteCliente")
  reviewsHotel              ReviewHotel[]       @relation("ReviewsHotelCliente")
  reviewsTour               ReviewTour[]        @relation("ReviewsTourCliente")
  cuponesHotelUsos          CuponHotelUso[]
}

model Comercio {
  id           Int       @id @default(autoincrement())
  usuarioId    Int       @unique
  nombre       String
  municipio    String
  departamento String?
  latitud      Float?
  longitud     Float?
  descripcion  String?
  historia     String?
  whatsapp     String?
  logoUrl      String?
  videoUrl     String?
  videoPosterUrl String?
  videoPublicId String?
  videoDuracionSegundos Float?
  videoDuracionOriginalSegundos Float?
  videoRecorteInicioSegundos Float?
  videoRecorteFinSegundos Float?
  videoAncho   Int?
  videoAlto    Int?
  videoBytes   Int?
  videoFormato String?
  videoMimeType String?
  calificacion Decimal   @default(0) @db.Decimal(3, 2)
  totalReviews Int       @default(0)
  totalVentas  Int       @default(0)
  verificado        Boolean           @default(false)
  estadoRegistro    EstadoComerciante @default(PENDIENTE_REVISION)
  motivoRechazo     String?
  revisadoPor       Int?
  revisadoAt        DateTime?
  whatsappVisible   Boolean           @default(false)
  whatsappAprobadoPor Int?
  whatsappAprobadoAt  DateTime?
  vereda            String?
  fotoDocumentoUrl  String?
  fotoDocumentoFrenteUrl  String?
  fotoDocumentoReversoUrl String?
  fotoDocumentoFrenteHash String?
  fotoDocumentoReversoHash String?
  activo            Boolean           @default(true)
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt
  deletedAt         DateTime?

  usuario           Usuario             @relation(fields: [usuarioId], references: [id])
  productos         Producto[]
  subPedidos        SubPedido[]
  reviews           Review[]
  visibilidades     VisibilidadPagada[]
  vistasProductos   VistaProducto[]
  conversaciones    Conversacion[]
  cuponComercio     CuponComercio[]
  comisiones        ComisionComercio[]
  cuentaDispersion  CuentaDispersionComercio?
  pagoDispersiones  PagoDispersion[]
  cambiosCriticos   CambioCriticoComercio[]
  solicitudesPublicidad SolicitudPublicidad[]
  configExpress         ConfigExpress?
  configHotel           ConfigHotel?
  configTour            ConfigTour?
  configTransporte      ConfigTransporte?
}

model Categoria {
  id       Int       @id @default(autoincrement())
  nombre   String    @unique
  slug     String    @unique
  icono    String?
  activa   Boolean   @default(true)

  productos Producto[]
}

model Producto {
  id                  Int          @id @default(autoincrement())
  comercioId          Int
  categoriaId         Int?
  nombre              String
  descripcion         String?
  precio              Decimal      @db.Decimal(12, 2)
  unidad              UnidadVenta
  stock               Int          @default(0)
  stockReservado      Int          @default(0)
  fotoUrl             String?
  imagenes            String[]     @default([])
  videoUrl            String?
  videoPosterUrl      String?
  videoPublicId       String?
  videoDuracionSegundos Float?
  videoDuracionOriginalSegundos Float?
  videoRecorteInicioSegundos Float?
  videoRecorteFinSegundos Float?
  videoAncho          Int?
  videoAlto           Int?
  videoBytes          Int?
  videoFormato        String?
  videoMimeType       String?
  activo              Boolean      @default(true)
  esExpress           Boolean      @default(false)
  tiempoEntregaMin    Int?
  diasAlistamientoMin Int          @default(1)
  diasAlistamientoMax Int          @default(3)
  alcance             AlcanceVenta @default(LOCAL)
  pesoKg              Decimal?     @db.Decimal(6, 2)
  createdAt           DateTime     @default(now())
  updatedAt           DateTime     @updatedAt
  deletedAt           DateTime?

  comercio         Comercio           @relation(fields: [comercioId], references: [id])
  categoria        Categoria?         @relation(fields: [categoriaId], references: [id])
  carrito          CarritoItem[]
  pedidoItems      PedidoItem[]
  historialPrecios PrecioHistorial[]
  reviews          ReviewProducto[]
  visibilidades    VisibilidadPagada[]
  ofertas          Oferta[]
  vistas           VistaProducto[]
  favoritos        Favorito[]
  solicitudesPublicidad SolicitudPublicidad[]
  itemsExpress          ItemPedidoExpress[]

  @@index([comercioId, activo])
  @@index([categoriaId, activo])
  @@index([alcance, activo])
}

model PrecioHistorial {
  id          Int      @id @default(autoincrement())
  productoId  Int
  precio      Decimal  @db.Decimal(12, 2)
  cambiadoPor Int
  createdAt   DateTime @default(now())

  producto Producto @relation(fields: [productoId], references: [id])
}

model Direccion {
  id           Int       @id @default(autoincrement())
  usuarioId    Int
  alias        String
  linea1       String
  barrio       String?
  municipio    String
  departamento String
  referencia   String?
  telefono     String?
  esPrincipal  Boolean   @default(false)
  deletedAt    DateTime?

  usuario Usuario  @relation(fields: [usuarioId], references: [id])
  pedidos Pedido[]
}

model CarritoItem {
  id              Int      @id @default(autoincrement())
  usuarioId       Int
  productoId      Int
  cantidad        Int
  precioAlAgregar Decimal  @db.Decimal(12, 2)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  usuario  Usuario  @relation(fields: [usuarioId], references: [id])
  producto Producto @relation(fields: [productoId], references: [id])

  @@unique([usuarioId, productoId])
}

model Pedido {
  id             Int          @id @default(autoincrement())
  compradorId    Int
  direccionId    Int?
  direccionTexto String
  estado         EstadoPedido @default(PENDIENTE_PAGO)
  subtotal       Decimal      @db.Decimal(12, 2)
  comisionTotal  Decimal      @db.Decimal(12, 2)
  total          Decimal      @db.Decimal(12, 2)
  costoEnvio     Decimal      @default(0) @db.Decimal(10, 2)
  notas          String?
  expiresAt      DateTime
  codigo         String?      @unique
  deletedAt      DateTime?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  cuponId        Int?
  cuponDescuento Decimal? @db.Decimal(12, 2)

  comprador  Usuario    @relation(fields: [compradorId], references: [id])
  direccion  Direccion? @relation(fields: [direccionId], references: [id])
  subPedidos SubPedido[]
  pagos      Pago[]
  cuponUso   CuponUso?
  cupon      Cupon?     @relation(fields: [cuponId], references: [id], onDelete: SetNull)

  @@index([compradorId])
}

model SubPedido {
  id                   Int             @id @default(autoincrement())
  pedidoId             Int
  comercioId           Int
  estado               EstadoSubPedido @default(CONFIRMADO)
  subtotal             Decimal         @db.Decimal(12, 2)
  comision             Decimal         @db.Decimal(12, 2)
  tasaComisionAplicada Decimal?        @db.Decimal(5, 4)
  neto                 Decimal         @db.Decimal(12, 2)
  notas                String?
  createdAt            DateTime        @default(now())
  updatedAt            DateTime        @updatedAt

  pedido   Pedido       @relation(fields: [pedidoId], references: [id])
  comercio Comercio     @relation(fields: [comercioId], references: [id])
  items    PedidoItem[]
  entrega  Entrega?
  dispersionPago PagoDispersion?

  @@index([comercioId])
  @@index([pedidoId])
}

model PedidoItem {
  id             Int     @id @default(autoincrement())
  subPedidoId    Int
  productoId     Int
  ofertaId       Int?
  cantidad       Int
  precioUnitario Decimal @db.Decimal(12, 2)
  subtotal       Decimal @db.Decimal(12, 2)

  subPedido SubPedido @relation(fields: [subPedidoId], references: [id])
  producto  Producto  @relation(fields: [productoId], references: [id])
  oferta    Oferta?   @relation(fields: [ofertaId], references: [id], onDelete: SetNull)

  @@index([ofertaId])
}

model Pago {
  id             Int        @id @default(autoincrement())
  pedidoId       Int
  monto          Decimal    @db.Decimal(12, 2)
  metodo         MetodoPago
  estado         EstadoPago @default(PENDIENTE)
  referencia     String?
  comprobanteUrl String?
  idempotencyKey String     @unique
  proveedor      ProveedorPago?
  moneda         String     @default("COP")
  providerPaymentId String? @unique
  providerCheckoutUrl String?
  providerReference String? @unique
  providerStatus String?
  providerPayload Json?
  confirmadoAt  DateTime?
  expiraAt      DateTime?
  verificadoPor  Int?
  verificadoAt   DateTime?
  notas          String?
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt

  pedido       Pedido           @relation(fields: [pedidoId], references: [id])
  eventos      PagoEvento[]
  dispersiones PagoDispersion[]

  @@index([pedidoId])
}

model CuentaDispersionComercio {
  id                   Int                    @id @default(autoincrement())
  comercioId           Int                    @unique
  proveedor            ProveedorPago          @default(SANDBOX)
  estado               EstadoCuentaDispersion @default(PENDIENTE_VERIFICACION)
  providerRecipientId  String?                @unique
  titularNombre        String
  tipoDocumento        TipoDocumento
  numeroDocumento      String
  bancoCodigo          String
  bancoNombre          String
  tipoCuenta           TipoCuentaDispersion
  numeroCuentaUltimos4 String
  numeroCuentaHash     String
  numeroCuentaCifrado  String?
  providerBankId       String?
  providerPayload      Json?
  emailNotificacion    String?
  telefonoNotificacion String?
  motivoRechazo        String?
  verificadaAt         DateTime?
  createdAt            DateTime               @default(now())
  updatedAt            DateTime               @updatedAt

  comercio     Comercio         @relation(fields: [comercioId], references: [id])
  dispersiones PagoDispersion[]

  @@index([estado])
  @@index([proveedor, providerRecipientId])
}

model CambioCriticoComercio {
  id                    Int      @id @default(autoincrement())
  comercioId            Int
  tipo                  String
  estado                String   @default("PENDIENTE")
  accion                String
  snapshotAnterior      Json
  snapshotNuevo         Json
  solicitadoPor         Int?
  revisadoPor           Int?
  motivo                String?
  productosDesactivados Int      @default(0)
  createdAt             DateTime @default(now())
  revisadoAt            DateTime?

  comercio Comercio @relation(fields: [comercioId], references: [id], onDelete: Cascade)

  @@index([comercioId, estado, createdAt])
  @@index([estado, createdAt])
}

model PagoEvento {
  id           Int           @id @default(autoincrement())
  pagoId       Int?
  proveedor    ProveedorPago
  eventoId     String?
  tipo         String
  estado       String?
  payload      Json
  firma        String?
  procesado    Boolean       @default(false)
  errorMensaje String?
  createdAt    DateTime      @default(now())
  processedAt  DateTime?

  pago Pago? @relation(fields: [pagoId], references: [id])

  @@unique([proveedor, eventoId])
  @@index([pagoId, createdAt])
}

model PagoDispersion {
  id                 Int                 @id @default(autoincrement())
  pagoId             Int
  subPedidoId        Int                 @unique
  comercioId         Int
  cuentaDispersionId Int
  proveedor          ProveedorPago
  estado             EstadoDispersionPago @default(PENDIENTE)
  montoBruto         Decimal             @db.Decimal(12, 2)
  comision           Decimal             @db.Decimal(12, 2)
  montoNeto          Decimal             @db.Decimal(12, 2)
  providerTransferId String?             @unique
  providerStatus     String?
  errorMensaje       String?
  programadaAt       DateTime?
  enviadaAt          DateTime?
  confirmadaAt       DateTime?
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt

  pago             Pago                       @relation(fields: [pagoId], references: [id])
  subPedido        SubPedido                  @relation(fields: [subPedidoId], references: [id])
  comercio         Comercio                   @relation(fields: [comercioId], references: [id])
  cuentaDispersion CuentaDispersionComercio   @relation(fields: [cuentaDispersionId], references: [id])

  @@index([comercioId, estado])
  @@index([pagoId, estado])
}

model Entrega {
  id           Int           @id @default(autoincrement())
  subPedidoId  Int           @unique
  repartidorId Int?
  estado       EstadoEntrega @default(ASIGNADA)
  direccion    String
  notas        String?
  pagoRepartidor Decimal?     @db.Decimal(10, 2)
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  subPedido  SubPedido @relation(fields: [subPedidoId], references: [id])
  repartidor Usuario?  @relation("EntregaRepartidor", fields: [repartidorId], references: [id])

  @@index([repartidorId])
}

model Review {
  id           Int      @id @default(autoincrement())
  comercioId   Int
  compradorId  Int
  pedidoId     Int      @unique
  calificacion Int
  comentario   String?
  createdAt    DateTime @default(now())

  comercio  Comercio @relation(fields: [comercioId], references: [id])
  comprador Usuario  @relation(fields: [compradorId], references: [id])
}

model TokenRecuperacion {
  id            Int       @id @default(autoincrement())
  usuarioId     Int
  codigoHash    String
  intentos      Int       @default(0)
  expiresAt     DateTime
  usadoEn       DateTime?
  reemplazadoEn DateTime?
  createdAt     DateTime  @default(now())

  usuario Usuario @relation(fields: [usuarioId], references: [id])

  @@index([usuarioId])
}

model SesionReset {
  id        Int       @id @default(autoincrement())
  usuarioId Int
  tokenHash String
  expiresAt DateTime
  usadoEn   DateTime?
  createdAt DateTime  @default(now())

  usuario Usuario @relation(fields: [usuarioId], references: [id])

  @@index([usuarioId])
}

model ReviewProducto {
  id           Int      @id @default(autoincrement())
  productoId   Int
  compradorId  Int
  calificacion Int
  comentario   String?
  createdAt    DateTime @default(now())

  producto  Producto @relation(fields: [productoId], references: [id])
  comprador Usuario  @relation(fields: [compradorId], references: [id])

  @@unique([compradorId, productoId])
  @@index([productoId])
}

model Config {
  clave     String   @id
  valor     String
  updatedAt DateTime @updatedAt
}

model Oferta {
  id          Int        @id @default(autoincrement())
  productoId  Int
  tipo        TipoOferta
  valor       Decimal    @db.Decimal(10,2)
  etiqueta    String?
  inicio      DateTime
  fin         DateTime
  activa      Boolean    @default(true)
  stockLimite Int?
  stockUsado  Int        @default(0)
  createdAt   DateTime   @default(now())

  producto    Producto     @relation(fields: [productoId], references: [id])
  pedidoItems PedidoItem[]

  @@index([productoId, activa, fin])
  @@index([activa, fin])
}

model VistaProducto {
  id         Int      @id @default(autoincrement())
  productoId Int
  comercioId Int
  usuarioId  Int?
  sesionId   String?
  createdAt  DateTime @default(now())

  producto Producto @relation(fields: [productoId], references: [id])
  comercio Comercio @relation(fields: [comercioId], references: [id])
  usuario  Usuario? @relation(fields: [usuarioId], references: [id])

  @@index([productoId, createdAt])
  @@index([comercioId, createdAt])
  @@index([usuarioId, createdAt])
}

model Notificacion {
  id        Int      @id @default(autoincrement())
  usuarioId Int
  tipo      String
  titulo    String
  mensaje   String
  leida     Boolean  @default(false)
  url       String?
  datos     Json?
  createdAt DateTime @default(now())

  usuario Usuario @relation(fields: [usuarioId], references: [id])

  @@index([usuarioId, leida, createdAt])
}

model Favorito {
  id         Int      @id @default(autoincrement())
  usuarioId  Int
  productoId Int
  createdAt  DateTime @default(now())

  usuario  Usuario  @relation(fields: [usuarioId], references: [id])
  producto Producto @relation(fields: [productoId], references: [id])

  @@unique([usuarioId, productoId])
  @@index([usuarioId, createdAt])
}

model BusquedaHistorial {
  id        Int      @id @default(autoincrement())
  usuarioId Int?
  sesionId  String?
  query     String
  createdAt DateTime @default(now())

  usuario Usuario? @relation(fields: [usuarioId], references: [id])

  @@index([usuarioId, createdAt])
  @@index([sesionId, createdAt])
}

model CampanaHero {
  id          Int      @id @default(autoincrement())
  tipo        String   @default("PUBLICIDAD")
  titulo      String
  subtitulo   String?
  imagenUrl   String
  ctaTexto    String   @default("Ver más")
  urlDestino  String
  activa      Boolean  @default(true)
  prioridad   Int      @default(0)
  inicio      DateTime
  fin         DateTime
  montoCOP    Decimal? @db.Decimal(10, 2)
  notas       String?
  vistas      Int      @default(0)
  clics       Int      @default(0)
  creadoPor   Int
  createdAt   DateTime @default(now())

  admin Usuario @relation("CampanaAdmin", fields: [creadoPor], references: [id])

  @@index([activa, fin])
}

// ─── FASE 2 ───────────────────────────────────────────────────

enum TipoDistribucionCupon {
  PUBLICO   // cualquiera que tenga el código puede usarlo
  ASIGNADO  // solo usuarios en CuponAsignacion pueden usarlo
}

model Cupon {
  id                    Int                    @id @default(autoincrement())
  codigo                String                 @unique
  tipo                  TipoOferta
  valor                 Decimal                @db.Decimal(10, 2)
  minimoCompra          Decimal?               @db.Decimal(12, 2)
  usosMaximos           Int?                   // tope global de redenciones
  usosMaximosPorUsuario Int?                   // tope por persona (null = ilimitado)
  usosActuales          Int                    @default(0)
  activo                Boolean                @default(true)
  inicio                DateTime
  fin                   DateTime
  soloNuevos            Boolean                @default(false)
  distribucion          TipoDistribucionCupon  @default(PUBLICO)
  createdAt             DateTime               @default(now())

  pedidos      Pedido[]
  usos         CuponUso[]
  comercios    CuponComercio[]
  asignaciones CuponAsignacion[]

  @@index([codigo, activo])
  @@index([activo, fin])
}

model CuponUso {
  id        Int      @id @default(autoincrement())
  cuponId   Int
  usuarioId Int
  pedidoId  Int      @unique
  createdAt DateTime @default(now())

  cupon   Cupon   @relation(fields: [cuponId], references: [id])
  usuario Usuario @relation(fields: [usuarioId], references: [id])
  pedido  Pedido  @relation(fields: [pedidoId], references: [id])

  @@index([cuponId, usuarioId])
}

model CuponComercio {
  id         Int @id @default(autoincrement())
  cuponId    Int
  comercioId Int

  cupon    Cupon    @relation(fields: [cuponId], references: [id], onDelete: Cascade)
