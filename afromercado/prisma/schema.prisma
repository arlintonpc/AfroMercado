generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── ENUMS ────────────────────────────────────────────────────

enum Rol {
  COMPRADOR
  COMERCIANTE
  REPARTIDOR
  ADMIN
}

enum UnidadVenta {
  KG
  UNIDAD
  LITRO
  PAQUETE
  DOCENA
  MANOJO
  ANIMAL
}

enum AlcanceVenta {
  LOCAL
  NACIONAL
  AMBOS
}

enum EstadoPedido {
  PENDIENTE_PAGO
  VERIFICANDO_PAGO
  PAGO_FALLIDO
  CONFIRMADO
  CANCELADO
  EXPIRADO
  ENTREGADO
}

enum EstadoSubPedido {
  CONFIRMADO
  EN_PREPARACION
  LISTO
  EN_CAMINO
  ENTREGADO
  CANCELADO
}

enum EstadoPago {
  PENDIENTE
  VERIFICANDO
  CONFIRMADO
  FALLIDO
  REEMBOLSADO
}

enum TipoOferta {
  PORCENTAJE
  VALOR_FIJO
}

enum MetodoPago {
  NEQUI
  DAVIPLATA
  TRANSFERENCIA
  EFECTIVO
  PASARELA
}

enum EstadoEntrega {
  ASIGNADA
  RECOGIDA
  EN_CAMINO
  ENTREGADA
  FALLIDA
}

enum TipoDocumento {
  CC
  TI
  CE
  PEP
  PASAPORTE
  NIT
}

enum TipoVehiculo {
  MOTO
  BICICLETA
  CARRO
  CAMIONETA
  TRICIMOTO
}

enum EstadoSolicitudRepartidor {
  PENDIENTE
  APROBADA
  RECHAZADA
}

enum EstadoComerciante {
  PENDIENTE_REVISION
  APROBADO
  RECHAZADO
  SUSPENDIDO
}

enum TipoOrganizacionTerritorial {
  CONSEJO_COMUNITARIO
  RESGUARDO_INDIGENA
  ZONA_RESERVA_CAMPESINA
  OTRA
}

enum TipoLiquidacion {
  COMERCIANTE
  REPARTIDOR
}

enum EstadoLiquidacion {
  PENDIENTE
  PAGADA
  CANCELADA
}

enum ProveedorPago {
  SANDBOX
  WOMPI
  PAYU
  EPAYCO
  MERCADOPAGO
}

enum TipoCuentaDispersion {
  AHORROS
  CORRIENTE
  BILLETERA_DIGITAL
}

enum EstadoCuentaDispersion {
  PENDIENTE_VERIFICACION
  VERIFICADA
  RECHAZADA
  SUSPENDIDA
}

enum EstadoDispersionPago {
  PENDIENTE
  PROGRAMADA
  ENVIADA
  CONFIRMADA
  FALLIDA
  CANCELADA
  REVERTIDA
}

// ─── MODELOS ──────────────────────────────────────────────────

model Usuario {
  id           Int       @id @default(autoincrement())
  nombre       String
  email        String    @unique
  telefono     String?
  avatarUrl    String?
  passwordHash String
  rol          Rol       @default(COMPRADOR)
  activo       Boolean   @default(true)
  motivoBloqueo String?
  bloqueadoPor  Int?
  bloqueadoAt   DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  deletedAt    DateTime?

  municipio          String?
  departamento       String?
  tipoDocumento      TipoDocumento?
  numeroDocumento    String?
  autorizacionDatos  Boolean   @default(false)
  autorizacionFecha  DateTime?
  passwordCambiadoAt DateTime?
  tokensRecuperacion TokenRecuperacion[]
  sesionesReset      SesionReset[]

  comercio                 Comercio?
  solicitudRepartidor      SolicitudRepartidor?
  pedidos                  Pedido[]
  direcciones          Direccion[]
  carrito              CarritoItem[]
  resenas              Resena[]
  campanasPublicitariasAdmin CampanaPublicitaria[] @relation("CampanaAdmin")
  solicitudesPublicidadRevisadas SolicitudPublicidad[] @relation("SolicitudPublicidadRevisor")
  notificaciones       Notificacion[]
  favoritos            Favorito[]
  busquedasHistorial   BusquedaHistorial[]
  vistasProducto       VistaProducto[]
  cuponUsos            CuponUso[]
  cuponAsignaciones    CuponAsignacion[]
  conversaciones            Conversacion[]      @relation("ConversacionComprador")
  mensajes                  Mensaje[]
  entregas                  Entrega[]           @relation("EntregaRepartidor")
  pushSubscripciones        PushSubscripcion[]
  liquidacionesBeneficiario Liquidacion[]       @relation("LiquidacionBeneficiario")
  liquidacionesCreadas      Liquidacion[]       @relation("LiquidacionAdmin")
  liquidacionesPagadas      Liquidacion[]       @relation("LiquidacionPagador")
  pedidosExpressCliente     PedidoExpress[]     @relation("PedidosExpressCliente")
  reservasHotel             ReservaHotel[]      @relation("ReservasHotelCliente")
  reservasTour              ReservaTour[]       @relation("ReservasTourCliente")
  reservasTransporte        ReservaTransporte[] @relation("ReservasTransporteCliente")
  reservasCulturales        ReservaCultural[]   @relation("ReservasCulturalesCliente")
  cuponesVerticalUsos       CuponVerticalUso[]
  disputasComoComprador     Disputa[]           @relation("DisputasComprador")
  facturas                  FacturaElectronica[]
  pqrsd                     Pqrsd[]
  calificacionesRecibidas   CalificacionRepartidor[] @relation("CalificacionesRecibidas")
  calificacionesEmitidas    CalificacionRepartidor[] @relation("CalificacionesEmitidas")
  perfilFidelizacion        PerfilFidelizacion?      @relation("PerfilFidelizacion")
  referidosHechos           PerfilFidelizacion[]     @relation("ReferidosHechos")
  ofertasEmpleoPublicadas   OfertaEmpleo[]           @relation("OfertasEmpleoPublicadas")
  hojaDeVida                HojaDeVida?
  postulacionesEmpleoEnviadas PostulacionEmpleo[]    @relation("PostulacionesEmpleoEnviadas")
  denunciasEmpleoHechas     DenunciaOfertaEmpleo[]
  inmueblesPublicados       Inmueble[]               @relation("InmueblesPublicados")
  denunciasInmuebleHechas   DenunciaInmueble[]        @relation("DenunciasInmuebleHechas")
  publicacionesCulturales            PublicacionCultural[]
  denunciasPublicacionCulturalHechas DenunciaPublicacionCultural[]
  likesPublicacionesCultura          LikePublicacionCultural[]
  denunciasProductoHechas   DenunciaProducto[]       @relation("DenunciasProductoHechas")
  comerciosSeguidos         SeguidorComercio[]
  vistasPublicacionCultural VistaPublicacionCultural[] @relation("VistasPublicacionUsuario")
  comentariosPublicacionCultural ComentarioPublicacionCultural[]
}

model Comercio {
  id           Int       @id @default(autoincrement())
  usuarioId    Int       @unique
  nombre       String
  municipio    String
  departamento String?
  latitud      Float?
  longitud     Float?
  descripcion  String?
  historia     String?
  whatsapp     String?
  logoUrl      String?
  videoUrl     String?
  videoPosterUrl String?
  videoPublicId String?
  videoDuracionSegundos Float?
  videoDuracionOriginalSegundos Float?
  videoRecorteInicioSegundos Float?
  videoRecorteFinSegundos Float?
  videoAncho   Int?
  videoAlto    Int?
  videoBytes   Int?
  videoFormato String?
  videoMimeType String?
  calificacion Decimal   @default(0) @db.Decimal(3, 2)
  totalReviews Int       @default(0)
  totalVentas  Int       @default(0)
  verificado        Boolean           @default(false)
  verificadoEtnico  Boolean           @default(false)
  organizacionTerritorialTipo   TipoOrganizacionTerritorial?
  organizacionTerritorialNombre String?
  organizacionTerritorialFecha  DateTime?
  disponibleComprasPublicas Boolean       @default(false)
  estadoRegistro    EstadoComerciante @default(PENDIENTE_REVISION)
  motivoRechazo     String?
  revisadoPor       Int?
  revisadoAt        DateTime?
  whatsappVisible   Boolean           @default(false)
  whatsappAprobadoPor Int?
  whatsappAprobadoAt  DateTime?
  vereda            String?
  rut                   String?
  camaraComercioNumero  String?
  camaraComercioUrl     String?
  fotoDocumentoUrl  String?
  fotoDocumentoFrenteUrl  String?
  fotoDocumentoReversoUrl String?
  fotoDocumentoFrenteHash String?
  fotoDocumentoReversoHash String?
  activo            Boolean           @default(true)
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt
  deletedAt         DateTime?

  usuario           Usuario             @relation(fields: [usuarioId], references: [id])
  productos         Producto[]
  subPedidos        SubPedido[]
  resenas           Resena[]
  campanasPublicitarias CampanaPublicitaria[]
  vistasProductos   VistaProducto[]
  conversaciones    Conversacion[]
  cuponComercio     CuponComercio[]
  comisiones        ComisionComercio[]
  cuentaDispersion  CuentaDispersionComercio?
  pagoDispersiones  PagoDispersion[]
  cambiosCriticos   CambioCriticoComercio[]
  solicitudesPublicidad SolicitudPublicidad[]
  configExpress         ConfigExpress?
  configHotel           ConfigHotel?
  configTour            ConfigTour?
  configTransporte      ConfigTransporte?
  gruposComplementoBiblioteca GrupoComplementoBiblioteca[]
  eventosCulturales     EventoCultural[]  @relation("EventosCulturalesComercio")
  publicacionesVitrina  PublicacionCultural[]
  seguidores            SeguidorComercio[]
  alianzasSocio         AlianzaSocio[]
  disputas              Disputa[]         @relation("DisputasComercio")
  configFiscal          ConfigFiscalComercio?
  facturas              FacturaElectronica[]
  ofertasEmpleo         OfertaEmpleo[]
  inmuebles             Inmueble[]
}

// IVA configurable por comercio (Fase 1.1) — apagado por defecto, solo el ADMIN
// lo activa. La tasa es por comercio porque cada uno puede tener un régimen
// tributario distinto; no hay override global como el de comisión.
model ConfigFiscalComercio {
  id                 Int       @id @default(autoincrement())
  comercioId         Int       @unique
  ivaActivo          Boolean   @default(false)
  ivaPorcentaje      Decimal   @default(19.00) @db.Decimal(5, 2)
  regimenTributario  String?
  activadoPor        Int?
  activadoAt         DateTime?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  comercio Comercio @relation(fields: [comercioId], references: [id])
}

enum GrupoCategoria {
  ANCESTRAL
  LOCAL
  AGRO
}

model Categoria {
  id       Int            @id @default(autoincrement())
  nombre   String         @unique
  slug     String         @unique
  icono    String?
  activa   Boolean        @default(true)
  grupo    GrupoCategoria @default(ANCESTRAL)

  productos Producto[]
}

model Producto {
  id                  Int          @id @default(autoincrement())
  comercioId          Int
  categoriaId         Int?
  nombre              String
  descripcion         String?
  precio              Decimal      @db.Decimal(12, 2)
  unidad              UnidadVenta
  stock               Int          @default(0)
  stockReservado      Int          @default(0)
  stockMinimo         Int          @default(0)
  stockBajoNotificadoAt DateTime?
  fotoUrl             String?
  imagenes            String[]     @default([])
  videoUrl            String?
  videoPosterUrl      String?
  videoPublicId       String?
  videoDuracionSegundos Float?
  videoDuracionOriginalSegundos Float?
  videoRecorteInicioSegundos Float?
  videoRecorteFinSegundos Float?
  videoAncho          Int?
  videoAlto           Int?
  videoBytes          Int?
  videoFormato        String?
  videoMimeType       String?
  activo              Boolean      @default(true)
  esExpress           Boolean      @default(false)
  tiempoEntregaMin    Int?
  diasAlistamientoMin Int          @default(1)
  diasAlistamientoMax Int          @default(3)
  alcance             AlcanceVenta @default(LOCAL)
  pesoKg              Decimal?     @db.Decimal(6, 2)
  menuSeccionId       Int?
  createdAt           DateTime     @default(now())
  updatedAt           DateTime     @updatedAt
  deletedAt           DateTime?

  comercio         Comercio           @relation(fields: [comercioId], references: [id])
  categoria        Categoria?         @relation(fields: [categoriaId], references: [id])
  carrito          CarritoItem[]
  pedidoItems      PedidoItem[]
  historialPrecios PrecioHistorial[]
  ofertas          Oferta[]
  vistas           VistaProducto[]
  solicitudesPublicidad SolicitudPublicidad[]
  anunciosUbicacion     AnuncioUbicacion[]
  itemsExpress          ItemPedidoExpress[]
  menuSeccion      MenuSeccion?       @relation("ProductoMenuSeccion", fields: [menuSeccionId], references: [id], onDelete: SetNull)
  gruposComplemento GrupoComplemento[]
  gruposComplementoAsignados ProductoGrupoComplemento[]
  denuncias        DenunciaProducto[]

  @@index([comercioId, activo])
  @@index([categoriaId, activo])
  @@index([alcance, activo])
  @@index([menuSeccionId])
}

enum MotivoDenunciaProducto {
  PRODUCTO_FALSO
  ESTAFA_DINERO
  CONTENIDO_INAPROPIADO
  VENDEDOR_SOSPECHOSO
  OTRO
}

enum EstadoDenunciaProducto {
  PENDIENTE
  DESESTIMADA
  PRODUCTO_BLOQUEADO
  CUENTA_BLOQUEADA
}

model DenunciaProducto {
  id            Int      @id @default(autoincrement())
  productoId    Int
  denuncianteId Int
  motivo        MotivoDenunciaProducto
  descripcion   String?
  estado        EstadoDenunciaProducto @default(PENDIENTE)
  revisadoPor   Int?
  revisadoAt    DateTime?
  notaRevision  String?
  createdAt     DateTime @default(now())

  producto    Producto @relation(fields: [productoId], references: [id], onDelete: Cascade)
  denunciante Usuario  @relation("DenunciasProductoHechas", fields: [denuncianteId], references: [id])

  @@unique([productoId, denuncianteId])
  @@index([estado, createdAt])
}

model PrecioHistorial {
  id          Int      @id @default(autoincrement())
  productoId  Int
  precio      Decimal  @db.Decimal(12, 2)
  cambiadoPor Int
  createdAt   DateTime @default(now())

  producto Producto @relation(fields: [productoId], references: [id])
}

model Direccion {
  id           Int       @id @default(autoincrement())
  usuarioId    Int
  alias        String
  linea1       String
  barrio       String?
  municipio    String
  departamento String
  referencia   String?
  telefono     String?
  esPrincipal  Boolean   @default(false)
  deletedAt    DateTime?

  usuario Usuario  @relation(fields: [usuarioId], references: [id])
  pedidos Pedido[]
}

model CarritoItem {
  id              Int      @id @default(autoincrement())
  usuarioId       Int
  productoId      Int
  cantidad        Int
  precioAlAgregar Decimal  @db.Decimal(12, 2)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  usuario  Usuario  @relation(fields: [usuarioId], references: [id])
  producto Producto @relation(fields: [productoId], references: [id])

  @@unique([usuarioId, productoId])
}

model Pedido {
  id             Int          @id @default(autoincrement())
  compradorId    Int
  direccionId    Int?
  direccionTexto String
  estado         EstadoPedido @default(PENDIENTE_PAGO)
  subtotal       Decimal      @db.Decimal(12, 2)
  comisionTotal  Decimal      @db.Decimal(12, 2)
  ivaTotal       Decimal      @default(0) @db.Decimal(12, 2)
  total          Decimal      @db.Decimal(12, 2)
  costoEnvio     Decimal      @default(0) @db.Decimal(10, 2)
  notas          String?
  expiresAt      DateTime
  codigo         String?      @unique
  deletedAt      DateTime?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  cuponId        Int?
  cuponDescuento Decimal? @db.Decimal(12, 2)

  comprador  Usuario    @relation(fields: [compradorId], references: [id])
  direccion  Direccion? @relation(fields: [direccionId], references: [id])
  subPedidos SubPedido[]
  pagos      Pago[]
  cuponUso   CuponUso?
  cupon      Cupon?     @relation(fields: [cuponId], references: [id], onDelete: SetNull)

  @@index([compradorId])
}

model SubPedido {
  id                   Int             @id @default(autoincrement())
  pedidoId             Int
  comercioId           Int
  estado               EstadoSubPedido @default(CONFIRMADO)
  subtotal             Decimal         @db.Decimal(12, 2)
  comision             Decimal         @db.Decimal(12, 2)
  tasaComisionAplicada Decimal?        @db.Decimal(5, 4)
  iva                  Decimal         @default(0) @db.Decimal(12, 2)
  neto                 Decimal         @db.Decimal(12, 2)
  notas                String?
  createdAt            DateTime        @default(now())
  updatedAt            DateTime        @updatedAt

  pedido   Pedido       @relation(fields: [pedidoId], references: [id])
  comercio Comercio     @relation(fields: [comercioId], references: [id])
  items    PedidoItem[]
  entrega  Entrega?
  dispersionPago PagoDispersion?

  @@index([comercioId])
  @@index([pedidoId])
}

model PedidoItem {
  id             Int     @id @default(autoincrement())
  subPedidoId    Int
  productoId     Int
  ofertaId       Int?
  cantidad       Int
  precioUnitario Decimal @db.Decimal(12, 2)
  subtotal       Decimal @db.Decimal(12, 2)

  subPedido SubPedido @relation(fields: [subPedidoId], references: [id])
  producto  Producto  @relation(fields: [productoId], references: [id])
  oferta    Oferta?   @relation(fields: [ofertaId], references: [id], onDelete: SetNull)

  @@index([ofertaId])
}

model Pago {
  id             Int        @id @default(autoincrement())
  pedidoId       Int
  monto          Decimal    @db.Decimal(12, 2)
  metodo         MetodoPago
  estado         EstadoPago @default(PENDIENTE)
  referencia     String?
  comprobanteUrl String?
  idempotencyKey String     @unique
  proveedor      ProveedorPago?
  moneda         String     @default("COP")
  providerPaymentId String? @unique
  providerCheckoutUrl String?
  providerReference String? @unique
  providerStatus String?
  providerPayload Json?
  confirmadoAt  DateTime?
  expiraAt      DateTime?
  verificadoPor  Int?
  verificadoAt   DateTime?
  notas          String?
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt

  pedido       Pedido           @relation(fields: [pedidoId], references: [id])
  eventos      PagoEvento[]
  dispersiones PagoDispersion[]

  @@index([pedidoId])
}

model CuentaDispersionComercio {
  id                   Int                    @id @default(autoincrement())
  comercioId           Int                    @unique
  proveedor            ProveedorPago          @default(SANDBOX)
  estado               EstadoCuentaDispersion @default(PENDIENTE_VERIFICACION)
  providerRecipientId  String?                @unique
  titularNombre        String
  tipoDocumento        TipoDocumento
  numeroDocumento      String
  bancoCodigo          String
  bancoNombre          String
  tipoCuenta           TipoCuentaDispersion
  numeroCuentaUltimos4 String
  numeroCuentaHash     String
  numeroCuentaCifrado  String?
  providerBankId       String?
  providerPayload      Json?
  emailNotificacion    String?
  telefonoNotificacion String?
  motivoRechazo        String?
  verificadaAt         DateTime?
  createdAt            DateTime               @default(now())
  updatedAt            DateTime               @updatedAt

  comercio     Comercio         @relation(fields: [comercioId], references: [id])
  dispersiones PagoDispersion[]

  @@index([estado])
  @@index([proveedor, providerRecipientId])
}

model CambioCriticoComercio {
  id                    Int      @id @default(autoincrement())
  comercioId            Int
  tipo                  String
  estado                String   @default("PENDIENTE")
  accion                String
  snapshotAnterior      Json
  snapshotNuevo         Json
  solicitadoPor         Int?
  revisadoPor           Int?
  motivo                String?
  productosDesactivados Int      @default(0)
  createdAt             DateTime @default(now())
  revisadoAt            DateTime?

  comercio Comercio @relation(fields: [comercioId], references: [id], onDelete: Cascade)

  @@index([comercioId, estado, createdAt])
  @@index([estado, createdAt])
}

enum EstadoDisputa {
  ABIERTA
  RESPONDIDA_COMERCIO
  RESUELTA_RECHAZADA
  RESUELTA_REEMBOLSO_TOTAL
  RESUELTA_REEMBOLSO_PARCIAL
  CERRADA_SIN_RESPUESTA
}

enum MotivoDisputa {
  PRODUCTO_NO_LLEGO
  PRODUCTO_DEFECTUOSO_O_DANADO
  PRODUCTO_INCOMPLETO
  PRODUCTO_DIFERENTE_AL_PEDIDO
  CALIDAD_NO_CONFORME
  SERVICIO_NO_PRESTADO
  COBRO_INCORRECTO
  OTRO
}

// Reclamo/disputa post-compra (Pedido vía SubPedido, Express, Hotel, Tour,
// Transporte — un solo modelo, polimórfico vía moduloOrigen/referenciaId,
// mismo patrón que AccionModeracion.targetTipo/targetId). El dinero de un
// reembolso aprobado NUNCA se revierte automáticamente en Wompi (no existe
// esa capacidad hoy) — se descuenta de la siguiente Liquidacion del comercio,
// y la devolución real al comprador es un paso manual que el admin marca.
model Disputa {
  id           Int    @id @default(autoincrement())
  moduloOrigen String // "PEDIDO" | "EXPRESS" | "HOTEL" | "TOUR" | "TRANSPORTE"
  referenciaId Int    // para "PEDIDO" es SubPedido.id, NO Pedido.id

  compradorId Int
  comercioId  Int

  motivo      MotivoDisputa
  descripcion String
  evidenciaUrls String[] @default([])

  montoOriginal            Decimal  @db.Decimal(12, 2)
  montoNetoOriginal        Decimal  @db.Decimal(12, 2)
  montoReembolsoSolicitado Decimal? @db.Decimal(12, 2)

  estado EstadoDisputa @default(ABIERTA)

  respuestaComercio     String?
  respuestaComercioUrls String[]  @default([])
  respondidoPor         Int?
  respondidoAt          DateTime?

  resolucion             String?
  montoReembolsoAprobado Decimal?  @db.Decimal(12, 2)
  montoDescuentoComercio Decimal?  @db.Decimal(12, 2)
  resueltoPor            Int?
  resueltoAt             DateTime?

  notaCreditoAplicada      Boolean   @default(false)
  notaCreditoLiquidacionId Int?
  reembolsoTransferidoAt   DateTime?
  reembolsoTransferidoPor  Int?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  comprador Usuario  @relation("DisputasComprador", fields: [compradorId], references: [id])
  comercio  Comercio @relation("DisputasComercio", fields: [comercioId], references: [id])

  @@index([moduloOrigen, referenciaId])
  @@index([comercioId, estado])
  @@index([compradorId, createdAt])
  @@index([estado, createdAt])
}

// Facturación electrónica DIAN (Fase 1.2) — abstracción de proveedor externo
// (ver services/facturacion/*), hoy solo con el proveedor no-op "NINGUNO".
// Mismo patrón polimórfico que Disputa: referenciaId es SubPedido.id para
// "PEDIDO", y el id de la reserva/pedido propio para los demás módulos.
enum EstadoFactura {
  PENDIENTE
  ENVIADA
  ACEPTADA
  RECHAZADA
  ERROR
  ANULADA
  OMITIDA
}

model FacturaElectronica {
  id           Int    @id @default(autoincrement())
  moduloOrigen String // "PEDIDO" | "EXPRESS" | "HOTEL" | "TOUR" | "TRANSPORTE" | "CULTURA"
  referenciaId Int

  comercioId  Int
  compradorId Int

  proveedor String        @default("NINGUNO")
  estado    EstadoFactura @default(PENDIENTE)

  subtotal Decimal @db.Decimal(12, 2)
  ivaTotal Decimal @default(0) @db.Decimal(12, 2)
  total    Decimal @db.Decimal(12, 2)

  cufe              String? @unique
  numeroFactura     String?
  pdfUrl            String?
  xmlUrl            String?
  providerFacturaId String?
  providerPayload   Json?

  errorMensaje       String?
  intentosFallidos   Int       @default(0)
  proximoReintentoAt DateTime?

  anuladaPor      Int?
  anuladaAt       DateTime?
  motivoAnulacion String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  comercio  Comercio @relation(fields: [comercioId], references: [id])
  comprador Usuario  @relation(fields: [compradorId], references: [id])

  @@unique([moduloOrigen, referenciaId])
  @@index([comercioId, estado])
  @@index([estado, proximoReintentoAt])
}

// PQRSD genérico (Fase 3.1) — canal de contacto con la PLATAFORMA misma, no con
// un comercio específico (eso ya lo cubre Disputa). Acepta visitantes sin
// cuenta (usuarioId nullable), por eso nombreContacto/emailContacto son
// obligatorios para poder cerrar el ciclo de atención sin depender de una cuenta.
enum TipoPqrsd {
  PETICION
  QUEJA
  RECLAMO
  SUGERENCIA
  DENUNCIA
}

enum EstadoPqrsd {
  ABIERTO
  EN_PROCESO
  RESPONDIDO
  CERRADO
}

model Pqrsd {
  id               Int         @id @default(autoincrement())
  usuarioId        Int?
  nombreContacto   String
  emailContacto    String
  telefonoContacto String?
  tipo             TipoPqrsd
  asunto           String
  mensaje          String
  moduloRelacionado String?
  referenciaId     Int?
  adjuntoUrls      String[]    @default([])
  estado           EstadoPqrsd @default(ABIERTO)
  prioridad        String      @default("NORMAL")
  respuesta        String?
  respondidoPor    Int?
  respondidoAt     DateTime?
  cerradoPor       Int?
  cerradoAt        DateTime?
  createdAt        DateTime    @default(now())
  updatedAt        DateTime    @updatedAt

  usuario Usuario? @relation(fields: [usuarioId], references: [id])

  @@index([estado, createdAt])
  @@index([usuarioId, createdAt])
  @@index([tipo, estado])
}

model PagoEvento {
  id           Int           @id @default(autoincrement())
  pagoId       Int?
  proveedor    ProveedorPago
  eventoId     String?
  tipo         String
  estado       String?
  payload      Json
  firma        String?
  procesado    Boolean       @default(false)
  errorMensaje String?
  createdAt    DateTime      @default(now())
  processedAt  DateTime?

  pago Pago? @relation(fields: [pagoId], references: [id])

  @@unique([proveedor, eventoId])
  @@index([pagoId, createdAt])
}

model PagoDispersion {
  id                 Int                 @id @default(autoincrement())
  pagoId             Int
  subPedidoId        Int                 @unique
  comercioId         Int
  cuentaDispersionId Int
  proveedor          ProveedorPago
  estado             EstadoDispersionPago @default(PENDIENTE)
  montoBruto         Decimal             @db.Decimal(12, 2)
  comision           Decimal             @db.Decimal(12, 2)
  montoNeto          Decimal             @db.Decimal(12, 2)
  providerTransferId String?             @unique
  providerStatus     String?
  errorMensaje       String?
  programadaAt       DateTime?
  enviadaAt          DateTime?
  confirmadaAt       DateTime?
  intentosFallidos   Int                 @default(0)
  proximoReintentoAt DateTime?
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt

  pago             Pago                       @relation(fields: [pagoId], references: [id])
  subPedido        SubPedido                  @relation(fields: [subPedidoId], references: [id])
  comercio         Comercio                   @relation(fields: [comercioId], references: [id])
  cuentaDispersion CuentaDispersionComercio   @relation(fields: [cuentaDispersionId], references: [id])

  @@index([comercioId, estado])
  @@index([pagoId, estado])
  @@index([estado, proximoReintentoAt])
}

// Anexo B, Fase 5: Entrega ahora sirve tanto a Marketplace (subPedidoId) como
// a Express en modo PLATAFORMA (pedidoExpressId) — mutuamente excluyentes,
// exactamente uno de los dos debe estar presente (constraint CHECK a nivel
// de BD, ver migración). No es el patrón polimórfico tipoEntidad/entidadId
// usado en Resena/Favorito/CuponVertical a propósito: aquí sí hace falta la
// relación real de Prisma para los joins de filtro (municipio, comprador)
// que ya usaba repartidor.controller.js — no hay 7 tablas duplicadas que
// consolidar, es una tabla que gana un segundo origen válido.
model Entrega {
  id              Int           @id @default(autoincrement())
  subPedidoId     Int?          @unique
  pedidoExpressId Int?          @unique
  repartidorId    Int?
  estado       EstadoEntrega @default(ASIGNADA)
  direccion    String
  notas        String?
  pagoRepartidor Decimal?     @db.Decimal(10, 2)
  // Tracking en vivo (Fase 4.1) — última posición conocida del repartidor,
  // persistida (no solo en memoria) para sobrevivir a un restart del backend.
  ultimaLatitud    Float?
  ultimaLongitud   Float?
  ultimaUbicacionAt DateTime?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  subPedido     SubPedido?     @relation(fields: [subPedidoId], references: [id])
  pedidoExpress PedidoExpress? @relation(fields: [pedidoExpressId], references: [id])
  repartidor Usuario?  @relation("EntregaRepartidor", fields: [repartidorId], references: [id])
  calificacion CalificacionRepartidor?

  @@index([repartidorId])
}

// Calificación del repartidor por el comprador (Fase 4.2) — solo tras ENTREGADA.
model CalificacionRepartidor {
  id           Int      @id @default(autoincrement())
  entregaId    Int      @unique
  repartidorId Int
  compradorId  Int
  calificacion Int
  comentario   String?
  createdAt    DateTime @default(now())

  entrega    Entrega @relation(fields: [entregaId], references: [id])
  repartidor Usuario @relation("CalificacionesRecibidas", fields: [repartidorId], references: [id])
  comprador  Usuario @relation("CalificacionesEmitidas", fields: [compradorId], references: [id])

  @@index([repartidorId])
}

// Anexo B, Fase 3 (unificación núcleo-vs-verticales): reemplaza a Review,
// ReviewProducto, ReviewHotel, ReviewTour, ReviewTransporte, ReviewExpress
// y ReviewCultura — mismo patrón polimórfico usado en Favorito (Fase 1).
enum TipoEntidadResenable {
  PEDIDO              // Review (Marketplace, nivel tienda/pedido completo)
  PRODUCTO            // ReviewProducto
  RESERVA_HOTEL
  RESERVA_TOUR
  RESERVA_TRANSPORTE
  PEDIDO_EXPRESS
  RESERVA_CULTURAL
}

model Resena {
  id           Int                  @id @default(autoincrement())
  tipoEntidad  TipoEntidadResenable
  entidadId    Int
  comercioId   Int?                 // desnormalizado a propósito: permite "todas las reseñas de este comercio" sin importar el vertical
  autorId      Int
  calificacion Int
  comentario   String?
  fotoUrls     String[]             @default([])
  videoUrl     String?
  createdAt    DateTime             @default(now())

  autor    Usuario  @relation(fields: [autorId], references: [id])
  comercio Comercio? @relation(fields: [comercioId], references: [id])

  // [tipoEntidad, entidadId] solo determina un único autor posible en 6 de los
  // 7 tipos (una reserva/pedido pertenece a un cliente); PRODUCTO es la
  // excepción real (muchos compradores distintos pueden reseñar el mismo
  // producto) — por eso autorId entra en la restricción, no solo el par.
  @@unique([tipoEntidad, entidadId, autorId])
  @@index([comercioId])
  @@index([tipoEntidad, entidadId])
}

model TokenRecuperacion {
  id            Int       @id @default(autoincrement())
  usuarioId     Int
  codigoHash    String
  intentos      Int       @default(0)
  expiresAt     DateTime
  usadoEn       DateTime?
  reemplazadoEn DateTime?
  createdAt     DateTime  @default(now())

  usuario Usuario @relation(fields: [usuarioId], references: [id])

  @@index([usuarioId])
}

model SesionReset {
  id        Int       @id @default(autoincrement())
  usuarioId Int
  tokenHash String
  expiresAt DateTime
  usadoEn   DateTime?
  createdAt DateTime  @default(now())

  usuario Usuario @relation(fields: [usuarioId], references: [id])

  @@index([usuarioId])
}

model Config {
  clave     String   @id
  valor     String
  updatedAt DateTime @updatedAt
}

model Oferta {
  id          Int        @id @default(autoincrement())
  productoId  Int
  tipo        TipoOferta
  valor       Decimal    @db.Decimal(10,2)
  etiqueta    String?
  inicio      DateTime
  fin         DateTime
  activa      Boolean    @default(true)
  stockLimite Int?
  stockUsado  Int        @default(0)
  createdAt   DateTime   @default(now())

  producto    Producto     @relation(fields: [productoId], references: [id])
  pedidoItems PedidoItem[]

  @@index([productoId, activa, fin])
  @@index([activa, fin])
}

model VistaProducto {
  id         Int      @id @default(autoincrement())
  productoId Int
  comercioId Int
  usuarioId  Int?
  sesionId   String?
  createdAt  DateTime @default(now())

  producto Producto @relation(fields: [productoId], references: [id])
  comercio Comercio @relation(fields: [comercioId], references: [id])
  usuario  Usuario? @relation(fields: [usuarioId], references: [id])

  @@index([productoId, createdAt])
  @@index([comercioId, createdAt])
  @@index([usuarioId, createdAt])
}

model Notificacion {
  id        Int      @id @default(autoincrement())
  usuarioId Int
  tipo      String
  titulo    String
  mensaje   String
  leida     Boolean  @default(false)
  url       String?
  datos     Json?
  createdAt DateTime @default(now())

  usuario Usuario @relation(fields: [usuarioId], references: [id])

  @@index([usuarioId, leida, createdAt])
}

// Favorito unificado (Anexo B, Fase 1 de la migración núcleo-vs-verticales):
// reemplaza los 7 modelos por vertical (Favorito+6 variantes) que existían
// antes, todos con la misma forma exacta salvo el nombre del campo de FK.
enum TipoEntidadFavorita {
  PRODUCTO
  CONFIG_HOTEL
  CONFIG_EXPRESS
  CONFIG_TOUR
  CONFIG_TRANSPORTE
  EVENTO_CULTURAL
  OFERTA_EMPLEO
  PUBLICACION_CULTURAL
}

model Favorito {
  id          Int                 @id @default(autoincrement())
  usuarioId   Int
  tipoEntidad TipoEntidadFavorita
  entidadId   Int
  createdAt   DateTime            @default(now())

  usuario Usuario @relation(fields: [usuarioId], references: [id], onDelete: Cascade)

  @@unique([usuarioId, tipoEntidad, entidadId])
  @@index([usuarioId, createdAt])
  @@index([tipoEntidad, entidadId])
}

model BusquedaHistorial {
  id        Int      @id @default(autoincrement())
  usuarioId Int?
  sesionId  String?
  query     String
  createdAt DateTime @default(now())

  usuario Usuario? @relation(fields: [usuarioId], references: [id])

  @@index([usuarioId, createdAt])
  @@index([sesionId, createdAt])
}

// Fidelización/referidos (Fase 5.2). Economía configurable vía Config (clave
// "fidelizacion.puntosPorCOP"), no hardcodeada — arranca en 1 punto por $1.000.
enum TipoMovimientoPuntos {
  GANADO_COMPRA
  GANADO_REFERIDO
  CANJEADO
  AJUSTE_ADMIN
}

model PerfilFidelizacion {
  id                    Int      @id @default(autoincrement())
  usuarioId             Int      @unique
  puntos                Int      @default(0)
  puntosAcumuladosTotal Int      @default(0)
  codigoReferido        String   @unique
  referidoPorId         Int?
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  usuario     Usuario            @relation("PerfilFidelizacion", fields: [usuarioId], references: [id])
  referidoPor Usuario?           @relation("ReferidosHechos", fields: [referidoPorId], references: [id])
  movimientos MovimientoPuntos[]

  @@index([codigoReferido])
}

model MovimientoPuntos {
  id           Int                  @id @default(autoincrement())
  perfilId     Int
  tipo         TipoMovimientoPuntos
  puntos       Int
  moduloOrigen String?
  referenciaId Int?
  descripcion  String?
  creadoPor    Int?
  createdAt    DateTime             @default(now())

  perfil PerfilFidelizacion @relation(fields: [perfilId], references: [id])

  @@index([perfilId, createdAt])
}

// ============================================================
//  Módulo Empleo / Bolsa de Trabajo comunitario (Fase 6)
//  Cualquier Usuario puede publicar una oferta (no solo Comercio — el
//  espíritu "comunitario" incluye a quien no tiene un negocio formal) y
//  cualquier Usuario puede postularse (el rol regula permisos de otros
//  módulos, no es una identidad excluyente de "quien busca trabajo").
//  Moderación ligera antes de publicar, dado el contexto de comunidades
//  vulnerables. La hoja de vida se snapshotea en cada postulación (mismo
//  espíritu que Disputa.montoOriginal) para que el postulante no pueda
//  "editar retroactivamente" lo que un empleador ya vio.
// ============================================================
enum EstadoOfertaEmpleo {
  BORRADOR
  PUBLICADA
  PAUSADA
  CERRADA
}

enum TipoContratoEmpleo {
  TIEMPO_COMPLETO
  MEDIO_TIEMPO
  POR_DIAS
  TEMPORAL
  OTRO
}

// Piloto Servicios Profesionales (Capítulo 3, sección 3.4.4): reutiliza
// OfertaEmpleo en el sentido inverso — un trabajador independiente ofrece
// su servicio en vez de que una empresa busque empleado. Sin postulación
// ni hoja de vida: el contacto es directo por WhatsApp.
enum TipoPublicacionEmpleo {
  OFERTA_EMPLEO
  OFRECE_SERVICIO
}

enum EstadoPostulacionEmpleo {
  ENVIADA
  VISTA
  PRESELECCIONADO
  RECHAZADA
  CONTRATADO
  RETIRADA
}

model OfertaEmpleo {
  id                Int                @id @default(autoincrement())
  publicadoPorId    Int
  comercioId        Int?
  tipoPublicacion   TipoPublicacionEmpleo @default(OFERTA_EMPLEO)
  titulo            String
  descripcion       String
  categoria         String?
  tipoContrato      TipoContratoEmpleo
  municipio         String
  departamento      String?
  salarioMin        Decimal?           @db.Decimal(12, 2)
  salarioMax        Decimal?           @db.Decimal(12, 2)
  salarioNegociable Boolean            @default(false)
  requisitos        String?
  vacantes          Int                @default(1)
  estado            EstadoOfertaEmpleo @default(BORRADOR)
  estadoModeracion  String             @default("PENDIENTE") // PENDIENTE | APROBADA | RECHAZADA
  revisadoPor       Int?
  revisadoAt        DateTime?
  motivoRechazoModeracion String?
  fechaCierre       DateTime?
  contactoWhatsapp  String?
  imagenUrl         String?
  preguntas         Json               @default("[]") // [{id, texto, tipo: TEXTO|SI_NO|OPCION_MULTIPLE, opciones?}]
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  deletedAt         DateTime?

  publicadoPor  Usuario             @relation("OfertasEmpleoPublicadas", fields: [publicadoPorId], references: [id])
  comercio      Comercio?           @relation(fields: [comercioId], references: [id])
  postulaciones PostulacionEmpleo[]
  denuncias     DenunciaOfertaEmpleo[]

  @@index([estado, estadoModeracion, municipio, createdAt])
  @@index([publicadoPorId])
  @@index([comercioId])
}

// Denuncias de ofertas de empleo (falsas, explotación laboral, discriminatorias,
// estafa, etc.). El admin puede desestimar, bloquear solo la oferta denunciada,
// o bloquear la cuenta completa del publicador — en ese último caso TODAS sus
// demás ofertas activas se cierran también (ver EmpleoService.resolverDenuncia).
enum MotivoDenunciaEmpleo {
  OFERTA_FALSA
  EXPLOTACION_LABORAL
  DISCRIMINATORIA
  ESTAFA_DINERO
  CONTENIDO_INAPROPIADO
  OTRO
}

enum EstadoDenunciaEmpleo {
  PENDIENTE
  DESESTIMADA
  OFERTA_BLOQUEADA
  CUENTA_BLOQUEADA
}

model DenunciaOfertaEmpleo {
  id             Int                  @id @default(autoincrement())
  ofertaEmpleoId Int
  denuncianteId  Int
  motivo         MotivoDenunciaEmpleo
  descripcion    String?
  estado         EstadoDenunciaEmpleo @default(PENDIENTE)
  revisadoPor    Int?
  revisadoAt     DateTime?
  notaRevision   String?
  createdAt      DateTime             @default(now())

  oferta      OfertaEmpleo @relation(fields: [ofertaEmpleoId], references: [id], onDelete: Cascade)
  denunciante Usuario      @relation(fields: [denuncianteId], references: [id])

  @@unique([ofertaEmpleoId, denuncianteId])
  @@index([estado, createdAt])
}

// ============================================================
//  Módulo Bienes Raíces / Inmuebles (vitrina, sin transacción)
//  Vitrina de predios formalizados — NO hay compra/venta ni checkout dentro
//  de la plataforma; el contacto siempre es por WhatsApp. Un marketplace
//  abierto de tierra no encaja en el territorio piloto (informalidad de
//  tenencia 52-60%, riesgo de tierra en disputa — ver Capítulo 3 del
//  Proyecto Maestro), así que a diferencia de Empleo la moderación NUNCA
//  se salta: un admin siempre debe verificar el documento de soporte
//  (evidencia de título, privado, solo lo ve un admin) antes de aprobar.
//  Cualquier Usuario puede publicar (mismo espíritu comunitario que Empleo).
// ============================================================
enum TipoInmueble {
  LOTE
  CASA
  APARTAMENTO
  FINCA
  LOCAL_COMERCIAL
  BODEGA
  OTRO
}

enum TipoOperacionInmueble {
  VENTA
  ARRIENDO
}

enum EstadoInmueble {
  BORRADOR
  PUBLICADO
  PAUSADO
  CERRADO
}

model Inmueble {
  id                      Int      @id @default(autoincrement())
  publicadorId            Int
  comercioId              Int?
  titulo                  String
  descripcion             String?
  tipoInmueble            TipoInmueble
  tipoOperacion           TipoOperacionInmueble
  precio                  Decimal  @db.Decimal(14, 2)
  areaM2                  Float?
  habitaciones            Int?
  banos                   Int?
  departamento            String
  municipio               String
  vereda                  String?
  direccionReferencia     String?
  latitud                 Float?
  longitud                Float?
  fotoUrls                String[] @default([])
  folioMatricula          String?
  documentoSoporteUrl     String?
  contactoWhatsapp        String?
  estado                  EstadoInmueble @default(BORRADOR)
  estadoModeracion        String   @default("PENDIENTE") // PENDIENTE | APROBADA | RECHAZADA
  revisadoPor             Int?
  revisadoAt              DateTime?
  motivoRechazoModeracion String?
  createdAt               DateTime @default(now())
  updatedAt               DateTime @updatedAt
  deletedAt               DateTime?

  publicador Usuario            @relation("InmueblesPublicados", fields: [publicadorId], references: [id])
  comercio   Comercio?          @relation(fields: [comercioId], references: [id])
  denuncias  DenunciaInmueble[]

  @@index([departamento, municipio])
  @@index([tipoInmueble, tipoOperacion])
  @@index([estado, estadoModeracion])
  @@index([publicadorId])
}

// Denuncias de publicaciones de inmuebles (publicación falsa, tierra en
// disputa, estafa, documento falso, etc.). El admin puede desestimar,
// bloquear solo la publicación denunciada, o bloquear la cuenta completa
// del publicador — en ese último caso TODAS sus demás publicaciones activas
// se cierran también (mismo patrón que DenunciaOfertaEmpleo).
enum MotivoDenunciaInmueble {
  PUBLICACION_FALSA
  TIERRA_EN_DISPUTA
  ESTAFA_DINERO
  DOCUMENTO_FALSO
  CONTENIDO_INAPROPIADO
  OTRO
}

enum EstadoDenunciaInmueble {
  PENDIENTE
  DESESTIMADA
  PUBLICACION_BLOQUEADA
  CUENTA_BLOQUEADA
}

model DenunciaInmueble {
  id            Int      @id @default(autoincrement())
  inmuebleId    Int
  denuncianteId Int
  motivo        MotivoDenunciaInmueble
  descripcion   String?
  estado        EstadoDenunciaInmueble @default(PENDIENTE)
  revisadoPor   Int?
  revisadoAt    DateTime?
  notaRevision  String?
  createdAt     DateTime @default(now())

  inmueble    Inmueble @relation(fields: [inmuebleId], references: [id], onDelete: Cascade)
  denunciante Usuario  @relation("DenunciasInmuebleHechas", fields: [denuncianteId], references: [id])

  @@unique([inmuebleId, denuncianteId])
  @@index([estado, createdAt])
}

model HojaDeVida {
  id               Int      @id @default(autoincrement())
  usuarioId        Int      @unique
  resumenPerfil    String?
  telefonoContacto String
  experiencia      Json     // [{empresa, cargo, desde, hasta, descripcion}]
  educacion        Json     // [{institucion, titulo, nivel, anio}]
  habilidades      String[] @default([])
  disponibilidad   String?
  cvUrl            String?  // PDF adjunto por el usuario (opcional, complementa el formulario)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  usuario Usuario @relation(fields: [usuarioId], references: [id])
}

model PostulacionEmpleo {
  id              Int                     @id @default(autoincrement())
  ofertaEmpleoId  Int
  postulanteId    Int
  hojaDeVidaId    Int
  // Snapshot de la hoja de vida al momento de postular (no solo la FK) —
  // evita que el candidato la edite después de que el empleador ya la vio.
  experienciaSnap Json
  educacionSnap   Json
  habilidadesSnap String[]                @default([])
  resumenPerfilSnap String?               // HojaDeVida.resumenPerfil al momento de postular
  disponibilidadSnap String?              // HojaDeVida.disponibilidad al momento de postular
  fotoSnapUrl     String?                 // Usuario.avatarUrl al momento de postular
  cvSnapUrl       String?                 // HojaDeVida.cvUrl al momento de postular
  respuestas      Json                    @default("[]") // [{preguntaId, texto, respuesta}]
  mensaje         String?
  estado          EstadoPostulacionEmpleo @default(ENVIADA)
  vistaAt         DateTime?
  notasPublicador String?
  createdAt       DateTime                @default(now())
  updatedAt       DateTime                @updatedAt

  oferta     OfertaEmpleo @relation(fields: [ofertaEmpleoId], references: [id])
  postulante Usuario      @relation("PostulacionesEmpleoEnviadas", fields: [postulanteId], references: [id])

  @@unique([ofertaEmpleoId, postulanteId])
  @@index([ofertaEmpleoId, estado])
  @@index([postulanteId])
}

// ─── TERAVIA ADS (PUBLICIDAD CENTRALIZADA) ─────────────────────

enum EstadoCampana {
  ACTIVA
  PAUSADA
  FINALIZADA
}

model CampanaPublicitaria {
  id               Int           @id @default(autoincrement())
  comercioId       Int?          // Opcional si la paga un usuario particular (ej. profesional independiente)
  anuncianteId     Int?          // Usuario que paga (si no tiene comercio)
  nombre           String
  presupuestoTotal Decimal       @db.Decimal(12, 2)
  presupuestoGastado Decimal     @default(0) @db.Decimal(12, 2)
  inicio           DateTime
  fin              DateTime
  estado           EstadoCampana @default(ACTIVA)
  notas            String?
  creadoPor        Int
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt

  comercio         Comercio?     @relation(fields: [comercioId], references: [id])
  admin            Usuario       @relation("CampanaAdmin", fields: [creadoPor], references: [id])
  anuncios         AnuncioUbicacion[]

  @@index([estado, fin])
}

enum ModuloAnuncio {
  VITRINA
  EMPLEOS
  PRODUCTOS
  HOTELES
  TOURS
  EXPRESS
  TRANSPORTE
  CULTURA
  BIENES_RAICES
}

enum FormatoAnuncio {
  NATIVO
  BANNER
  VIDEO
}

model AnuncioUbicacion {
  id               Int           @id @default(autoincrement())
  campanaId        Int
  modulo           ModuloAnuncio
  formato          FormatoAnuncio
  
  // Relaciones específicas (solo una debería estar llena según el módulo)
  productoId       Int?
  ofertaEmpleoId   Int?
  habitacionId     Int?
  
  // Contenido estático si es un banner o video suelto (ej. para Vitrina)
  titulo           String?
  subtitulo        String?
  mediaUrl         String?
  urlDestino       String?
  ctaTexto         String?       @default("Ver más")

  // Paquete/formato de origen (ej. "BANNER_CARRUSEL", "IRRUPTOR_BIENVENIDA",
  // "VIDEO_HISTORIA", "PUBLICIDAD", "SOCIAL") — sin esto, modulo+formato no
  // alcanzan para distinguir un banner de carrusel de un irruptor de
  // bienvenida (ambos son VITRINA+BANNER). GET /campanas/activas lo usa
  // para filtrar por ?tipo= y para excluir los formatos exclusivos de la
  // rotación general del hero cuando no se pide un tipo específico.
  tipoCampana      String?
  
  // Opciones de segmentación
  alcance          String        @default("NACIONAL") // "MUNICIPIO" | "DEPARTAMENTO" | "NACIONAL"
  departamento     String?
  municipio        String?
  etiqueta         String        @default("Patrocinado")
  
  activa           Boolean       @default(true)
  createdAt        DateTime      @default(now())

  campana          CampanaPublicitaria @relation(fields: [campanaId], references: [id], onDelete: Cascade)
  producto         Producto?           @relation(fields: [productoId], references: [id], onDelete: SetNull)
  metricas         MetricaPublicitaria[]

  @@index([modulo, activa])
}

enum TipoMetricaAnuncio {
  IMPRESION
  CLIC
  CARRITO
  CONVERSION_COMPRA
  POSTULACION_EMPLEO
}

model MetricaPublicitaria {
  id               Int                @id @default(autoincrement())
  anuncioId        Int
  tipoEvento       TipoMetricaAnuncio
  usuarioId        Int?
  sesionId         String?
  valorAtribuido   Decimal            @default(0) @db.Decimal(12, 2) // Ej. Valor de la compra si es CONVERSION
  // Referencia externa idempotente (ej. "pedidoItem:123") — evita duplicar
  // una atribución de venta si el webhook/flujo de confirmación se reprocesa.
  // Null en IMPRESION/CLIC/CARRITO, donde no aplica (Postgres no choca por
  // NULLs repetidos en un unique compuesto).
  referenciaExterna String?
  createdAt        DateTime           @default(now())

  anuncio          AnuncioUbicacion   @relation(fields: [anuncioId], references: [id], onDelete: Cascade)

  @@unique([anuncioId, tipoEvento, referenciaExterna])
  @@index([anuncioId, tipoEvento, createdAt])
}

// ─── FASE 2 ───────────────────────────────────────────────────

enum TipoDistribucionCupon {
  PUBLICO   // cualquiera que tenga el código puede usarlo
  ASIGNADO  // solo usuarios en CuponAsignacion pueden usarlo
}

model Cupon {
  id                    Int                    @id @default(autoincrement())
  codigo                String                 @unique
  tipo                  TipoOferta
  valor                 Decimal                @db.Decimal(10, 2)
  minimoCompra          Decimal?               @db.Decimal(12, 2)
