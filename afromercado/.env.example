# ============================================
#  AfroMercado — Variables de entorno (ejemplo)
#  Copia este archivo como .env y rellena los valores reales.
#  NUNCA subas el archivo .env real a Git.
# ============================================

NODE_ENV=development
PORT=3000

# Base de datos PostgreSQL
DATABASE_URL="postgresql://usuario:password@localhost:5432/afromercado?schema=public"

# Seguridad JWT (genera una clave larga y aleatoria para producción)
JWT_SECRET="cambia-esto-por-una-clave-larga-y-secreta"
JWT_EXPIRES_IN="24h"

# Reglas de negocio
COMISION_PORCENTAJE=0.10
BCRYPT_ROUNDS=10

# Orígenes permitidos para CORS (separados por coma, sin barra final).
# En producción pon el dominio del frontend en Vercel, ej:
#   CORS_ORIGIN=https://afromercado.vercel.app
# Si se deja vacío, se permiten todos los orígenes (solo para desarrollo).
CORS_ORIGIN=

# Notificaciones Email (Resend)
RESEND_API_KEY=re_xxxx
EMAIL_FROM=AfroMercado <notificaciones@afromercado.co>
ADMIN_EMAIL=admin@afromercado.co

# ── Notas de producción ─────────────────────────────────────
# - NODE_ENV=production
# - NO definas PORT en Render (la plataforma lo asigna).
# - DATABASE_URL: usa la connection string de Neon con sslmode=require.
# - JWT_SECRET: genera uno con
#     node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
